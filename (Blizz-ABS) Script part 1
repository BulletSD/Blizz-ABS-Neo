    # Тип навыка: [ТИП, ВЗРЫВ, РАДИУС_ВЗРЫВА, ID_СНАРЯДА]
    def self.type(id)
      case id
      when 2  then [SHOOT,  EXPLTarget, 2.5, 27]  # Вызывая инферно
      when 3  then [SHOOT,  EXPLTarget, 2.0, 36]  # Акво какофония
      when 4  then [DIRECT, EXPLTarget, 1.0, 39]  # Месть Гайи
      when 5  then [BEAM,   EXPLTarget, 1.0, 42]  # Вихрь разрушения
      when 6  then [BEAM,   EXPLTarget, 1.0, 48]  # Ярость демона
      when 7  then [BEAM,   EXPLTarget, 1.0, 103] # Сисюща ультима
      when 10 then [SHOOT,  EXPLTarget, 2.0, 27]  # Огонь демонов
      when 12 then [BEAM,   EXPLTarget, 1.0, 33]  # Демон лексус
      else         [DIRECT, EXPLNone]             # Обычный
      end
    end
    
    # ID комбо
    def self.combo(id)
      0
    end
    
    # Скорость полета снаряда
    def self.projectile_speed(id)
      case id
      when 3 then 4
      else        5
      end
    end
    
    # Сила отбрасывания
    def self.knockback(id)
      case id
      when 1, 10 then 0 # Лечение / Огонь демонов
      when 8, 12 then 2 # Яд / Демон лексус
      else            1
      end
    end
    
    # Радиус действия (клетки)
    def self.range(id)
      case id
      when 2, 10           then 10.0
      when 3, 5, 6, 7, 12  then 20.0
      when 4               then 6.0
      else                      1.0
      end
    end
    
    # Задержка (Cooldown)
    def self.penalty(id)
      24
    end
    
    # Кадры анимации
    def self.frames(id)
      [3, 3, 3, 3]
    end
    
    # Зарядка [Тип, Время]
    def self.charge(id)
      [CHARGENone, 0]
    end
    
    # Кадры зарядки
    def self.charge_frames(id)
      [3, 3, 3, 3]
    end
    
    # Время жизни ловушки (сек)
    def self.trap(id)
      10
    end
    
    # Призыв существа [Тип, ID Врага, ID Актера]
    def self.summon(id)
      [SUMMONPet, 0, 0]
    end
    

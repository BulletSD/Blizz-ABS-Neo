  #----------------------------------------------------------------------------
  # Настройка управления и привязка клавиш.
  #============================================================================
  module Control
    
    CUSTOM_CONTROLS = true        # Использовать пользовательские настройки управления
    DISABLE_DEFAULT = false       # Отключить стандартные действия (C, B, L, R)
    
    # Синтаксис клавиш: "Key['Название_Клавиши']"
    # Эти значения обрабатываются Input модулем Blizz-ABS.
    UP              = "Key['Arrow Up']"     # Вверх
    LEFT            = "Key['Arrow Left']"   # Влево
    DOWN            = "Key['Arrow Down']"   # Вниз
    RIGHT           = "Key['Arrow Right']"  # Вправо
    
    PREVPAGE        = "Key['Q']"            # Пред. страница (Меню)
    NEXTPAGE        = "Key['W']"            # След. страница (Меню)
    CONFIRM         = "Key['S']"            # Подтверждение / Действие
    CANCEL          = "Key['A']"            # Отмена / Меню
    
    ATTACK          = "Key['Z']"            # Атака
    DEFEND          = "Key['X']"            # Защита / Блок
    SKILL           = "Key['C']"            # Использование навыка
    ITEM            = "Key['V']"            # Использование предмета
    
    SELECT          = "Key['O']"            # Выбор цели
    
    HUD             = "Key['F3']"           # Вкл/Выкл HUD
    HOTKEY          = "Key['F4']"           # Вкл/Выкл панель быстрого доступа
    MINIMAP         = "Key['F5']"           # Вкл/Выкл миникарту
    
    RUN             = "Key['Space']"        # Бег
    SNEAK           = "Key['Left Alt']"     # Красться
    JUMP            = "Key['D']"            # Прыжок
    TURN            = "Key['S']"            # Поворот на месте (удерживать)
    
  end
  

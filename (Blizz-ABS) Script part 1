  #============================================================================
  # :: Combos
  #----------------------------------------------------------------------------
  # Программирование последовательностей действий (комбо) для AI.
  #============================================================================
  module Combos
    
    # Общее количество действий в комбо (для безопасности циклов)
    def self.total_actions(com)
      case com.id
      when 1 then 6
      when 2 then 2
      when 3 then 3
      when 4 then 3
      when 6 then 3
      else        1
      end
    end
    
    # Логика команд комбо
    def self.commands(com)
      case com.id
      when 1 # Архангел
        case com.aid
        when 1 then [[COMAttack], [COMWait, 50], [COMGoTo, 2]]
        when 2 then [[COMMove, DIRAwayPlayer, 5], [COMWait, 40], [COMGoTo, 3]]
        when 3 then [[COMMove, DIRAwayPlayer, 5], [COMWait, 40], [COMGoTo, 4]]
        when 4 then [[COMSkill, 9], [COMWait, 100], [COMGoTo, 5]]
        when 5 then [[COMMove, DIRAwayPlayer, 3], [COMDefend, 60], [COMGoTo, 6]]
        when 6 then [[COMWait, 40], [COMJump, DIRAwayPlayer, 7], [COMGoTo, 1]]
        else []
        end
      when 2 # Ведьма
        case com.aid
        when 1 then [[COMAttack], [COMWait, 40], [COMGoTo, 2]]
        when 2 then [[COMCondition, VARCharacter, VALHp, '<=', VARGame, 600],
                     [COMWait, 40], [COMSkill, 8], [COMWait, 40], [COMGoTo, 1]]
        else []
        end
      when 3 # Смертоносец
        case com.aid
        when 1 then [[COMAttack], [COMWait, 50], [COMGoTo, 2]]
        when 2 then [[COMSkill, 10], [COMWait, 40], [COMGoTo, 3]]
        when 3 then [[COMMove, DIRAwayPlayer, 15], [COMWait, 40], [COMGoTo, 1]]
        else []
        end
      when 4 # Водный демон
        case com.aid
        when 1 then [[COMAttack], [COMWait, 40], [COMGoTo, 2]]
        when 2 then [[COMSkill, 3], [COMWait, 40], [COMGoTo, 3]]
        when 3 then [[COMDefend, 6], [COMWait, 40], [COMGoTo, 1]]
        else []
        end
      when 5 # Плеватель
        case com.aid
        when 1 then [[COMSkill, 11]]
        else []
        end
      when 6 # Демон Эдема
        case com.aid
        when 1 then [[COMAttack], [COMWait, 50], [COMGoTo, 2]]
        when 2 then [[COMSkill, 10], [COMWait, 40], [COMGoTo, 3]]
        when 3 then [[COMMove, DIRAwayPlayer, 15], [COMWait, 40], [COMGoTo, 1]]
        else []
        end
      else []
      end
    end
    
    # Данные анимации для комбо (для продвинутых пользователей)
    def self.anim_data(com)
      return [0, [3, 3, 3, 3], '', false]
    end
    
  end
  
end

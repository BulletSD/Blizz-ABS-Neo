  #============================================================================
  # :: Alignments
  #----------------------------------------------------------------------------
  # Настройка фракций (групп) и их отношений друг к другу.
  #============================================================================
  module Alignments
    
    GROUPS           = [1, 2, 3, 4, 5, 6] # Список всех ID групп
    LIFELESS_GROUPS  = [4]                # Неживые объекты (нельзя атаковать)
    LINKED_GROUPS    = [5, 6]             # Связанные группы (суммоны)
    PERMANENT_GROUPS = [5, 6]             # Не исчезают при смене карты
    
    ACTOR_GROUP      = 1                  # Группа Игрока
    ENEMY_GROUP      = 2                  # Группа Врагов
    
    # Кто является врагом для группы ID?
    def self.enemies(id)
      case id
      when 1 then [2]               # Игрок бьет Врагов
      when 2 then [1, 3, 5, 6]      # Враги бьют Игрока, Нейтралов и Суммонов
      when 5 then [2]               # Суммоны бьют Врагов
      else []
      end
    end
    
    # Кто является союзником для группы ID?
    def self.allies(id)
      case id
      when 1 then [1]
      when 2 then [2]
      when 5 then [5, 6]
      when 6 then [5, 6]
      else []
      end
    end
    
    # Кто нейтрален для группы ID?
    def self.neutral(id)
      []
    end
    
  end
  

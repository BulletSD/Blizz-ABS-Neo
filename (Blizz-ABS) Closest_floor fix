#==============================================================================
# ■ Fix: Защита closest_floor от бесконечного BFS (ФИНАЛЬНАЯ ВЕРСИЯ)
#------------------------------------------------------------------------------
# Устраняет зависание игры ("Script is hanging"), возникающее когда враг
# умирает рядом с границей карты над тайлом NO_FLOOR_TAGS. Оригинальный метод
# использовал RPG::Table для отметки посещённых клеток, но Table некорректно
# обрабатывает координаты за пределами карты (0 <= x < width), из-за чего BFS
# бесконечно генерирует "теневые" координаты снаружи карты и никогда не
# завершается. Подтверждено диагностикой: pending_size рос без ограничения
# уже через несколько шагов после смерти врага у южной границы карты.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#
# ВАЖНО: этот патч должен быть вставлен В ФАЙЛ ПОСЛЕ оригинального
# определения BlizzABS::Utility (то есть после Script part 2), либо в
# отдельный скрипт, расположенный НИЖЕ part 2 в списке скриптов редактора.
#==============================================================================

module BlizzABS
  class Utility

    # Максимальное количество проверяемых клеток за один поиск.
    # При достижении лимита поиск прерывается вместо зависания игры.
    CLOSEST_FLOOR_MAX_STEPS = 2000

    # Защита от повторного создания алиаса при повторной загрузке скрипта
    unless method_defined?(:closest_floor_fix_original)
      alias closest_floor_fix_original closest_floor
    end

    #--------------------------------------------------------------------------
    # closest_floor (переопределение)
    #  x - начальная x-координата (в тайлах)
    #  y - начальная y-координата (в тайлах)
    #  Безопасный BFS-поиск ближайшего проходимого (не NO_FLOOR_TAGS) тайла.
    #  Строго ограничен границами карты и максимальным числом шагов поиска.
    #--------------------------------------------------------------------------
    def closest_floor(x, y)
      map_w = $game_map.width
      map_h = $game_map.height

      # Если стартовые координаты уже вне карты — сразу отдаём исходные,
      # без запуска поиска (защита от некорректного вызова).
      return [x, y] if x < 0 || y < 0 || x >= map_w || y >= map_h

      # Hash вместо Table: гарантированно корректно хранит только
      # реально посещённые пары координат, без побочных эффектов
      # записи/чтения за границами массива.
      visited = {}
      pending = [[x, y]]
      visited[[x, y]] = true
      steps = 0

      until pending.empty?
        steps += 1

        # Аварийный выход: превышен лимит шагов поиска.
        # Это предотвращает "Script is hanging" даже в случае, если
        # проходимый пол физически отсутствует в разумном радиусе
        # (например, вся ближайшая область — вода/пропасть).
        if steps > CLOSEST_FLOOR_MAX_STEPS
          return [x, y]
        end

        cx, cy = pending.shift

        # Нашли проходимый тайл — возвращаем его координаты
        unless BlizzABS::Config::NO_FLOOR_TAGS.include?($game_map.terrain_tag(cx, cy))
          return [cx, cy]
        end

        # Проверяем 4 соседние клетки строго в границах карты.
        # Координаты за пределами карты никогда не попадают в очередь —
        # именно это отсутствовало в оригинальной реализации с Table.
        neighbors = [[cx, cy + 1], [cx - 1, cy], [cx + 1, cy], [cx, cy - 1]]

        neighbors.each do |nx, ny|
          next if nx < 0 || ny < 0 || nx >= map_w || ny >= map_h
          next if visited[[nx, ny]]
          visited[[nx, ny]] = true
          pending.push([nx, ny])
        end
      end

      # Проходимый пол не найден в пределах карты — фоллбек на исходные
      # координаты (труп/дроп появится на тайле смерти врага "как есть").
      [x, y]
    end

  end
end

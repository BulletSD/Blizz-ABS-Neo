  #============================================================================
  # START Font Color Option Integration
  #============================================================================
  # Настройте доступные цвета для шрифта здесь
  FONT_COLORS = [
    # Название цвета        # Значение цвета (R, G, B)
    ["Белый",                [255, 255, 255]],
    ["Голубой",              [170, 220, 255]],
    ["Красный",              [255, 120, 120]],
    ["Зеленый",              [120, 255, 120]],
    ["Желтый",               [255, 255, 150]],
    ["Фиолетовый",           [210, 170, 255]],
    ["Серый",                [192, 192, 192]]
  ]

  # Метод для получения названия цвета по индексу
  def self.get_font_color_name(index)
    index = 0 if index.nil? || FONT_COLORS[index].nil?
    return FONT_COLORS[index][0]
  end

  # Метод для получения объекта цвета по индексу
  def self.get_font_color(index)
    index = 0 if index.nil? || FONT_COLORS[index].nil?
    color_data = FONT_COLORS[index][1]
    return Color.new(color_data[0], color_data[1], color_data[2])
  end
  
  # Метод для получения количества доступных цветов
  def self.font_color_count
    return FONT_COLORS.size
  end
  #============================================================================
  # END Font Color Option Integration
  #============================================================================

  # change only if changed in the 3DPBC script
  CAM_Variable = 25 if CAM_AVAILABLE

end


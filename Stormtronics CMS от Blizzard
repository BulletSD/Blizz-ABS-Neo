class Scene_S1L
  # По умолчанию false - значит, считаем, что вызваны из Меню Игры
  def initialize(from_title = false)
    @from_title = from_title
  end

  def main
    # Подготовка фона
    @sprite = Sprite.new
    @background = Sprite.new
    if $game_temp and $game_temp.background_snapshot
      @background.bitmap = $game_temp.background_snapshot
      $game_temp.background_snapshot = nil
    end

    # Окно выбора
    s1 = "Слот 1 (Файлы 1-4)"
    s2 = "Слот 2 (Файлы 5-8)"
    @command_window = Window_Command.new(240, [s1, s2])
    @command_window.back_opacity = 160
    @command_window.x = 320 - @command_window.width / 2
    @command_window.y = 240 - @command_window.height / 2

    Graphics.transition
    loop do
      Graphics.update
      Input.update
      update
      if $scene != self
        break
      end
    end
    Graphics.freeze
    @command_window.dispose
    @background.dispose
    @sprite.dispose
    
    # Плавный переход при возврате на титульник
    if $scene.is_a?(Scene_Title)
      Graphics.transition
      Graphics.freeze
    end
  end

  def update
    @command_window.update
    
    # --- Кнопка B (Отмена) ---
    if Input.trigger?(Input::B)
      $game_system.se_play($data_system.cancel_se)
      if @from_title
        $scene = Scene_Title.new      # Возврат на титульный
      else
        $scene = Scene_Map.new        # Возврат в игру
      end
      return
    end

    # --- Кнопка C (Подтверждение) ---
    if Input.trigger?(Input::C)
      case @command_window.index
      when 0 # Выбран Слот 1
        if slot1_has_saves?
          $game_system.se_play($data_system.decision_se)
          $scene = Scene_Load.new(@from_title)
        else
          $game_system.se_play($data_system.buzzer_se)
        end
      when 1 # Выбран Слот 2
        if slot2_has_saves?
          $game_system.se_play($data_system.decision_se)
          $scene = Scene_Load2.new(@from_title)
        else
          $game_system.se_play($data_system.buzzer_se)
        end
      end
      return
    end
  end

  def slot1_has_saves?
    for i in 0..3
      return true if FileTest.exist?("Save#{i+1}.rxdata")
    end
    return false
  end

  def slot2_has_saves?
    for i in 0..3
      return true if FileTest.exist?("Save#{i+1}.rxdata2")
    end
    return false
  end
end

  self.contents.draw_text(4, (@item_max-1)*32, 100, 32, '[Убрать]')
end

  def build_item_list
    list = []
    if @slot_id == 0
      weapon_set = $data_classes[@actor.class_id].weapon_set
      (1...$data_weapons.size).each do |i|
        next unless $game_party.weapon_number(i) > 0
        list.push($data_weapons[i]) if weapon_set.include?(i)
      end
    else
      armor_kind = ARMOR_KIND_BY_SLOT[@slot_id]
      return [] unless armor_kind
      armor_set = $data_classes[@actor.class_id].armor_set
      (1...$data_armors.size).each do |i|
        next unless $game_party.armor_number(i) > 0
        next unless armor_set.include?(i)
        list.push($data_armors[i]) if $data_armors[i].kind == armor_kind
      end
    end
    list
  end

  def draw_item(i)
    item = @data[i]
    number = item.is_a?(RPG::Weapon) ? $game_party.weapon_number(item.id) :
                                      $game_party.armor_number(item.id)
    self.contents.font.color = normal_color
    bitmap = RPG::Cache.icon(item.icon_name)
    self.contents.blt(4, 4 + i*32, bitmap, Rect.new(0, 0, 24, 24))
    self.contents.draw_text(32, i*32, 212, 32, item.name, 0)
    self.contents.draw_text(228, i*32, 24, 32, number.to_s, 2)
  end

  def data
    @data[self.index]
  end

  def update_help
    @help_window.set_text(data == nil ? '' : data.description)
  end
end


    @slot_id  = slot_id
    super(928, 256, 352, 224)
    self.active = self.visible = false
    self.z, self.index = 3000, -1
    refresh
  end

  def update_actor(actor, slot_id = @slot_id)
    @actor   = actor
    @slot_id = slot_id
    refresh
  end

  def refresh
  if self.contents != nil
    self.contents.dispose
    self.contents = nil
  end
  @data = build_item_list
  @data.push(nil)
  @item_max = @data.size
  self.contents = Bitmap.new(width - 32, @item_max * 32)
  (0...@item_max-1).each { |i| draw_item(i) }

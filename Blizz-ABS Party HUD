# ■ Window_Skill_Hotkey
#------------------------------------------------------------------------------
#  Окно навыков для назначения горячих клавиш
#==============================================================================
class Window_Skill_Hotkey < Window_Skill
  def initialize(actor)
    super
    @column_max = 1
    self.width = 320
    self.height = 416
    self.y = 0
    self.z = 21000
    self.cursor_rect.empty
    self.active = false
    refresh
  end
end


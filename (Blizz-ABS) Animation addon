#==============================================================================
# ■ Interpreter - Сокращения и хелперы для событий
#------------------------------------------------------------------------------
# Методы для удобного запуска анимаций и настройки спрайтов из команд события.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

class Interpreter

  #============================================================================
  # :: Шорткаты для анимаций игрока
  #============================================================================
  
  # Запуск пользовательской анимации игрока
  # name      - имя анимации
  # duration  - длительность (0 = авто)
  # loop_anim - зациклить? (true/false)
  # move      - разрешить движение? (true/false)
  def anim(name, duration = 0, loop_anim = false, move = false)
    $game_player.play_custom_animation(name, duration, loop_anim, move)
  end

  # Ожидание окончания пользовательской анимации игрока
  # Блокирует выполнение события, пока анимация активна.
  def wait_anim
    if $game_player.custom_animation_playing?
      @wait_count = 1
      return false
    end
    true
  end

  #============================================================================
  # :: Настройка спрайтов врагов и событий
  #============================================================================

  # Применяет конфигурацию спрайтов к объекту события (приватный метод)
  def _apply_sprite_config(event, prefix, config)
    return unless event

    # Гарантируем инициализацию конфига
    event.abs_sprite_config ||= {}
    c = event.abs_sprite_config

    if prefix
      c[:walk]   = config[:walk]   || "#{prefix}walk"
      c[:idle]   = config[:idle]   || "#{prefix}idle"
      c[:attack] = config[:attack] || "#{prefix}attack"
      c[:block]  = config[:block]  || "#{prefix}block"
      c[:skill]  = config[:skill]  || "#{prefix}magic"
      c[:default_direction] = config[:default_direction] || ABS_CustomOverlay::ENEMY_DEFAULT_DIRECTION
    else
      c.merge!(config)
    end

    c[:animation_speeds] = config[:animation_speeds] if config[:animation_speeds]
  end
  private :_apply_sprite_config

  # Настраивает спрайты текущего события (вызывается из команды события)
  def setup_enemy_sprites(prefix = nil, config = {})
    event = get_character(0)
    _apply_sprite_config(event, prefix, config)
  end

  # Настраивает спрайты события по его ID на текущей карте
  def setup_enemy_by_id(event_id, prefix = nil, config = {})
    event = $game_map.events[event_id]
    _apply_sprite_config(event, prefix, config)
  end

  #============================================================================
  # :: Управление действиями врагов
  #============================================================================

  # Активирует использование навыка текущим событием
  def enemy_use_skill(skill_id, duration = nil)
    event = get_character(0)
    return unless event

    if duration.nil? || duration <= 0
      duration = ABS_CustomOverlay.get_skill_duration(skill_id)
    end

    event.abs_using_skill      = true
    event.abs_current_skill_id = skill_id
    event.abs_skill_duration   = duration
  end

  # Запускает произвольную анимацию для текущего события
  def enemy_anim(name, duration = 0, loop_anim = false, move = false)
    event = get_character(0)
    return unless event
    event.play_custom_animation(name, duration, loop_anim, move)
  end

end


# Применение патча, если целевой метод найден
if target_class
  target_class.class_eval do

    # Защита от повторного создания алиаса
    unless method_defined?(:abs_exactdrop_create_drop_event)
      alias_method :abs_exactdrop_create_drop_event, :create_drop_event
    end

    #==========================================================================
    # :: Переопределение create_drop_event
    #--------------------------------------------------------------------------
    # Принудительно выравнивает координаты созданного события (дропа/трупа)
    # по тайловым координатам смерти врага с учетом границ карты.
    #==========================================================================
    
    def create_drop_event(x, y, character_name, character_hue = 0, trigger = 1)
      # Вызов оригинального метода Blizz-ABS
      event = abs_exactdrop_create_drop_event(x, y, character_name, character_hue, trigger)

      if event
        tx = x.to_i
        ty = y.to_i

        # Ограничение координат границами текущей карты
        if $game_map
          map_w = $game_map.width rescue 0
          map_h = $game_map.height rescue 0
          tx = [[tx, 0].max, map_w - 1].min if map_w > 0
          ty = [[ty, 0].max, map_h - 1].min if map_h > 0
        end

        # Установка точных тайловых координат
        event.x = tx
        event.y = ty
      end


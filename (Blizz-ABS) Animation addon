#==============================================================================

if defined?(BlizzABS::Processor)
  ABS_CorpseFixMixin.apply_to(BlizzABS::Processor)
elsif defined?(BlizzABS)
  ABS_CorpseFixMixin.apply_to(BlizzABS)
end

#==============================================================================
# ■ Blizz-ABS - Отложенное удаление врагов (Death Delay)
#------------------------------------------------------------------------------
# Откладывает вызов remove_enemy до окончания анимации смерти.
# Предотвращает преждевременное появление трупа и лута на карте.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

module ABS_DeathDelay
  
  #============================================================================
  # :: Настройки и очередь
  #============================================================================
  
  # Сдвиг задержки для точной синхронизации (отрицательное = раньше, положительное = позже)
  DEATH_DELAY_OFFSET = -3
  
  # Очередь отложенных действий [кадры_до_выполнения, блок]
  @queue = []

  #============================================================================
  # :: Расчет задержки
  #============================================================================
  
  # Вычисляет задержку в кадрах для конкретного врага на основе длины анимации смерти
  def self.death_delay_frames(enemy)
    return 0 unless enemy && enemy.respond_to?(:abs_sprite_config)

    cfg = enemy.abs_sprite_config rescue nil
    return 0 if cfg.nil?

    key = cfg[:death]
    return 0 if key.nil? || key.to_s.empty?

    # Используем встроенный метод для подсчета кадров (автоматически поддерживает цепочки _a/_b)
    total_frames = ABS_CustomOverlay.total_frames_for_key(enemy, key, cfg)
    return 0 if total_frames <= 0

    # Определение скорости анимации смерти
    spd = if cfg[:animation_speeds] && cfg[:animation_speeds][:death]
            cfg[:animation_speeds][:death].to_i
          else
            ABS_CustomOverlay.get_animation_speed(:death).to_i
          end
    spd = 1 if spd < 1

    # Расчет итоговой задержки с учетом смещения (минимум 1 кадр)
    delay = (total_frames * spd) + DEATH_DELAY_OFFSET
    [delay, 1].max
  end

  #============================================================================
  # :: Управление очередью
  #============================================================================

  # Добавляет действие в очередь отложенного выполнения
  def self.enqueue(frames, &block)
    frames = [frames.to_i, 0].max
    @queue << [frames, block]
  end

  # Ожидание фактического завершения анимации смерти (с проверкой флага)
  def self.wait_until_death_complete(enemy, max_frames, &block)
    max_frames = [max_frames.to_i, 1].max
    
    enqueue(1) do
      done = enemy.nil? || 
             (enemy.erased rescue false) || 
             enemy.instance_variable_get(:@abs_death_animation_complete)
      
      if done || max_frames <= 1
        block.call if block
      else
        wait_until_death_complete(enemy, max_frames - 1, &block)
      end
    end
  end

  # Обновление очереди (вызывается каждый кадр)
  def self.update
    return if @queue.empty?
    
    # Обрабатываем только элементы, присутствующие на начало кадра.
    # Новые элементы, добавленные внутри callback, уйдут на следующий кадр.
    current_queue = @queue.dup
    @queue.clear
    
    current_queue.each do |item|
      item[0] -= 1
      
      if item[0] <= 0
        begin
          item[1].call if item[1]
        rescue
        end
      else
        @queue << item
      end
    end
  end
  
end

#==============================================================================
# ■ Scene_Map - Интеграция обновления очереди
#==============================================================================

class Scene_Map
  
  unless method_defined?(:abs_deathdelay_update)
    alias abs_deathdelay_update update
  end
  
  def update
    ABS_DeathDelay.update
    abs_deathdelay_update
  end
  
end

#==============================================================================
# ■ BlizzABS - Перехват remove_enemy
#==============================================================================

target_class = nil
if defined?(BlizzABS::Processor) && BlizzABS::Processor.method_defined?(:remove_enemy)
  target_class = BlizzABS::Processor
elsif defined?(BlizzABS) && BlizzABS.method_defined?(:remove_enemy)
  target_class = BlizzABS
end

if target_class
  target_class.class_eval do
    
    unless method_defined?(:abs_deathdelay_remove_enemy_now)
      alias abs_deathdelay_remove_enemy_now remove_enemy
    end

    # Переопределение remove_enemy для отложенного выполнения
    def remove_enemy(enemy)
      return abs_deathdelay_remove_enemy_now(enemy) if enemy.nil?

      # Защита от повторного добавления в очередь
      return if enemy.instance_variable_get(:@abs_deathdelay_pending)

      delay = ABS_DeathDelay.death_delay_frames(enemy)
      
      if delay > 0
        enemy.instance_variable_set(:@abs_deathdelay_pending, true)
        
        ABS_DeathDelay.enqueue(delay) do
          enemy.instance_variable_set(:@abs_deathdelay_pending, nil)
          # Удаляем врага только если он всё ещё присутствует на карте
          if $game_map.events[enemy.id] == enemy
            abs_deathdelay_remove_enemy_now(enemy)
          end
        end
      else
        abs_deathdelay_remove_enemy_now(enemy)
      end
    end
    
  end
end

#==============================================================================
# ■ Blizz-ABS - Исправление порядка отрисовки (Draw Order Fix)
#------------------------------------------------------------------------------
# Принудительно устанавливает Z-координату врагов, трупов и лута ниже слоя игрока,
# предотвращая их отрисовку поверх персонажа.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

module ABS_DrawOrderFix

  #============================================================================
  # :: Проверка типа объекта
  #============================================================================
  
  # Определяет, должен ли объект рисоваться ниже игрока
  # Возвращает true для врагов, трупов и лута
  def self.force_under_player?(ch)
    return false if ch.nil?
    return false if $game_player && ch == $game_player

    # Прямая проверка класса врага
    return true if defined?(Map_Enemy) && ch.is_a?(Map_Enemy)

    # Проверка через Map_Battler (если есть battler-враг)
    if defined?(Map_Battler) && ch.is_a?(Map_Battler)
      b = ch.battler rescue nil
      return true if defined?(Game_Enemy) && b.is_a?(Game_Enemy)
    end

    # Труп определяется по суффиксу _crp в имени персонажа
    cname = ch.character_name.to_s rescue ""
    return true if cname =~ /_crp$/i

    # Лут: проверка через метод dropped? или по имени события
    return true if ch.respond_to?(:dropped?) && ch.dropped?
    
    evname = ch.event.name.to_s rescue ""
    return true if evname =~ /^DROP\d+$/i

    false
  end

  #============================================================================
  # :: Работа с Z-координатами
  #============================================================================

  # Получает экранные Z-координаты игрока
  def self.player_z
    return 0 unless $game_player
    ($game_player.screen_z(0) rescue 0).to_i
  end

  # Ограничивает Z-координату объекта строго ниже игрока
  def self.clamp_below_player(current_z)
    target = player_z - 1
    target = 0 if target < 0
    [current_z.to_i, target].min
  end

end

#==============================================================================
# ■ Sprite_Character - Коррекция Z-слоя базовых спрайтов
#------------------------------------------------------------------------------
# Принудительно опускает Z-слой врагов, трупов и лута ниже игрока,
# чтобы они не перекрывали персонажа при отрисовке.
#==============================================================================

class Sprite_Character

  # Защита от повторного алиаса
  unless method_defined?(:abs_draworderfix_update)
    alias abs_draworderfix_update update
  end

  def update
    abs_draworderfix_update
    
    # Применяем коррекцию только к специфичным объектам (враги, трупы, лут)
    if ABS_DrawOrderFix.force_under_player?(@character)
      self.z = ABS_DrawOrderFix.clamp_below_player(self.z)
    end
  end

end

#==============================================================================
# ■ Control_Sprite_Character - Коррекция Z-слоя оверлейных спрайтов
#------------------------------------------------------------------------------
# Синхронизирует Z-слой оверлея с базовым спрайтом для корректной отрисовки.
# Патч применяется только если класс Control_Sprite_Character существует.
#==============================================================================

if defined?(Control_Sprite_Character)

  class Control_Sprite_Character

    # Защита от повторного алиаса
    unless method_defined?(:abs_draworderfix_abs_overlay_update)
      alias abs_draworderfix_abs_overlay_update abs_overlay_update
    end

    def abs_overlay_update
      abs_draworderfix_abs_overlay_update
      
      # Пропускаем, если спрайт оверлея не создан или уже уничтожен
      return if @abs_overlay_sprite.nil? || @abs_overlay_sprite.disposed?
      
      # Применяем коррекцию Z-слоя для оверлея
      if ABS_DrawOrderFix.force_under_player?(@character)
        @abs_overlay_sprite.z = ABS_DrawOrderFix.clamp_below_player(@abs_overlay_sprite.z)
      end
    end

  end

end # if defined?(Control_Sprite_Character)

#==============================================================================
# ■ Blizz-ABS - Отключение прижимания живых врагов (No Enemy Clamping)
#------------------------------------------------------------------------------
# Модификация модуля ABS_DrawOrderFix: живые враги больше не принудительно
# рисуются под игроком. Под игроком по Z-оси остаются только трупы и лут.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

if defined?(ABS_DrawOrderFix)
  
  # Защита от повторного создания алиаса для singleton-метода
  unless ABS_DrawOrderFix.respond_to?(:abs_no_enemy_clamp_force_under_player)
    
    class << ABS_DrawOrderFix
      
      alias_method :abs_no_enemy_clamp_force_under_player, :force_under_player?

      # Переопределение метода: исключает живых врагов из принудительного Z-сдвига
      def force_under_player?(ch)
        return false if ch.nil?
        return false if $game_player && ch == $game_player

        # Живые враги (Map_Enemy) не прижимаются под игрока
        return false if defined?(Map_Enemy) && ch.is_a?(Map_Enemy)
        
        # Проверка через Map_Battler на наличие Game_Enemy
        if defined?(Map_Battler) && ch.is_a?(Map_Battler)
          b = ch.battler rescue nil
          return false if defined?(Game_Enemy) && b.is_a?(Game_Enemy)
        end

        # Для остальных объектов (трупы, лут) используется оригинальная логика
        abs_no_enemy_clamp_force_under_player(ch)
      end
      
    end
    
  end
  
end # if defined?(ABS_DrawOrderFix)

#==============================================================================
# ■ Interpreter - Быстрые команды для настройки анимаций (Shortcuts)
#------------------------------------------------------------------------------
# Вспомогательные методы для настройки спрайтов врагов и персонажей.
# Используются в блоках «Выполнить скрипт» (Call Script) внутри событий.
# Учтено ограничение поля скрипта в RMXP (37 символов на строку).
#==============================================================================

class Interpreter

  #============================================================================
  # :: se - Настройка анимаций для ТЕКУЩЕГО события
  #--------------------------------------------------------------------------
  # Применяет набор анимаций к персонажу текущего события (игрок или эвент).
  # Не работает для врагов Blizz-ABS (Map_Enemy) — для них используйте se2().
  #============================================================================
  
    def se(prefix, w = 128, h = 128)
    event = get_character(0)
    return unless event && event.respond_to?(:abs_sprite_config=)
    event.abs_sprite_config ||= {} # Принудительная инициализация
    c = event.abs_sprite_config
    c[:frame_width]       = w
    c[:frame_height]      = h
    c[:idle]              = "#{prefix}idle_#{w}x#{h}"
    c[:walk]              = "#{prefix}walk_#{w}x#{h}"
    c[:run]               = "#{prefix}run_#{w}x#{h}"
    c[:attack]            = "#{prefix}attack_#{w}x#{h}"
    c[:block]             = "#{prefix}block_#{w}x#{h}"
    c[:skill]             = "#{prefix}skill_#{w}x#{h}"
    c[:death]             = "#{prefix}death_#{w}x#{h}"
    c[:default_direction] = 6
  end

  def se3(id, prefix, dir = 4, w = nil, h = nil)
    event = $game_map.events[id]
    return unless event && event.respond_to?(:abs_sprite_config=)
    
    event.abs_sprite_config ||= {}
    c = event.abs_sprite_config
    
    # Если размер указан явно — используем его и добавляем суффикс к именам
    if w && h
      c[:frame_width]  = w
      c[:frame_height] = h
      c[:idle]    = "#{prefix}idle_#{w}x#{h}"
      c[:walk]    = "#{prefix}walk_#{w}x#{h}"
      c[:attack]  = "#{prefix}attack_#{w}x#{h}"
      c[:block]   = "#{prefix}block_#{w}x#{h}"
      c[:skill]   = "#{prefix}magic_#{w}x#{h}"
      c[:death]   = "#{prefix}death_#{w}x#{h}"
    else
      # Старое поведение — без суффикса, дефолтный размер
      c[:idle]    = "#{prefix}idle"
      c[:walk]    = "#{prefix}walk"
      c[:attack]  = "#{prefix}attack"
      c[:block]   = "#{prefix}block"
      c[:skill]   = "#{prefix}magic"
      c[:death]   = "#{prefix}death"
    end
    
    c[:default_direction] = dir
  end

  def se2(event_id, prefix, w = 128, h = 128, dir = 6)
    enemy = nil
    if defined?(BlizzABS) && $BlizzABS && $BlizzABS.respond_to?(:battlers)
      enemy = $BlizzABS.battlers.find { |b| b && b.respond_to?(:id) && b.id == event_id }
    end
    enemy ||= ($game_map.events[event_id] rescue nil)
    
    return unless enemy && enemy.respond_to?(:abs_sprite_config=)
    enemy.abs_sprite_config ||= {} # Принудительная инициализация
    c = enemy.abs_sprite_config
    
    c[:frame_width]       = w
    c[:frame_height]      = h
    c[:idle]              = "#{prefix}idle_#{w}x#{h}"
    c[:walk]              = "#{prefix}walk_#{w}x#{h}"
    c[:run]               = "#{prefix}run_#{w}x#{h}"
    c[:attack]            = "#{prefix}attack_#{w}x#{h}"
    c[:block]             = "#{prefix}block_#{w}x#{h}"
    c[:skill]             = "#{prefix}skill_#{w}x#{h}"
    c[:death]             = "#{prefix}death_#{w}x#{h}"
    c[:default_direction] = dir
  end
end

#==============================================================================
# ■ Map_Enemy - Автоматическая настройка конфига по имени врага
#------------------------------------------------------------------------------
# При создании Map_Enemy автоматически определяет префикс и размер кадра
# по имени врага из базы данных и заполняет abs_sprite_config.
# Устраняет необходимость ручного вызова se2() для каждого врага.
#==============================================================================

if defined?(Map_Enemy)
  class Map_Enemy

    #==========================================================================
    # :: Перехват метода initialize
    #==========================================================================
    
    unless method_defined?(:abs_overlay_initialize_auto)
      alias abs_overlay_initialize_auto initialize
    end

    def initialize(map_id, event, id = 0, *args)
      # Передаем id обратно в *args, чтобы не нарушить цепочку алиасов
      abs_overlay_initialize_auto(map_id, event, id, *args)
      abs_overlay_auto_setup(id)
    end

    #==========================================================================
    # :: Автоматическая настройка конфига
    #--------------------------------------------------------------------------
    # Заполняет abs_sprite_config на основе имени врага из $data_enemies.
    #==========================================================================
    
           def abs_overlay_auto_setup(enemy_id)
      return if enemy_id.to_i <= 0
      
      # ЯДЕРНАЯ ИНИЦИАЛИЗАЦИЯ
      cfg = instance_variable_get(:@abs_sprite_config)
      cfg = {} if cfg.nil? || !cfg.is_a?(Hash)
      
      # Не перезаписываем, если конфиг уже задан вручную
      if cfg[:idle] && !cfg[:idle].to_s.empty?
        instance_variable_set(:@abs_sprite_config, cfg)
        return
      end

      enemy_data = $data_enemies[enemy_id] rescue nil
      return if enemy_data.nil?

      prefix = "#{enemy_data.name.to_s.gsub(' ', '')}_"

      w, h = abs_overlay_detect_frame_size(prefix)
      dir = abs_overlay_detect_direction(prefix, w, h)

      cfg[:frame_width]       = w
      cfg[:frame_height]      = h
      cfg[:idle]              = "#{prefix}idle_#{w}x#{h}"
      cfg[:walk]              = "#{prefix}walk_#{w}x#{h}"
      cfg[:run]               = "#{prefix}run_#{w}x#{h}"
      cfg[:attack]            = "#{prefix}attack_#{w}x#{h}"
      cfg[:block]             = "#{prefix}block_#{w}x#{h}"
      cfg[:skill]             = "#{prefix}skill_#{w}x#{h}"
      cfg[:death]             = "#{prefix}death_#{w}x#{h}"
      cfg[:default_direction] = dir

      enemy_name_key = prefix.chomp('_')
      if defined?(ABS_CustomOverlay::ENEMY_ANIMATION_SPEEDS)
        speeds = ABS_CustomOverlay::ENEMY_ANIMATION_SPEEDS[enemy_name_key]
        cfg[:animation_speeds] = speeds if speeds
      end
      
      # Сохраняем обратно в объект
      instance_variable_set(:@abs_sprite_config, cfg)
    end

    #==========================================================================
    # :: Вспомогательные методы
    #==========================================================================

    # Определяет размер кадра путем поиска существующих файлов на диске
    def abs_overlay_detect_frame_size(prefix)
      candidates = [
        [128, 128], [64, 64], [96, 96], [160, 160], [192, 192],
        [256, 256], [284, 220], [320, 240], [400, 299]
      ]

      candidates.each do |w, h|
        base_key = "#{prefix}idle_#{w}x#{h}"
        # Проверяем одиночный файл или начало цепочки (_a)
        if ABS_CustomOverlay.bitmap(base_key) || 
           ABS_CustomOverlay.bitmap(ABS_CustomOverlay.chain_key(base_key, 0))
          return [w, h]
        end
      end

      # Фоллбек на глобальные настройки
      [ABS_CustomOverlay::FRAME_WIDTH, ABS_CustomOverlay::FRAME_HEIGHT]
    end

    # Определяет направление спрайта по умолчанию
    def abs_overlay_detect_direction(prefix, w, h)
      # Словарь исключений для врагов, чей спрайт по умолчанию смотрит вправо (6)
      exceptions = {
        # "EnemyName" => 6
      }
      
      name = prefix.chomp('_')
      exceptions[name] || ABS_CustomOverlay::ENEMY_DEFAULT_DIRECTION
    end

  end
end

#==============================================================================
# ■ Map_Battler - Перехват использования навыков (для всех батлеров)
#------------------------------------------------------------------------------
# Отслеживает использование навыков любыми батлерами (игрок, враги, союзники)
# для запуска соответствующих оверлей-анимаций.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

if defined?(Map_Battler)
  class Map_Battler

    #==========================================================================
    # :: Перехват метода use_skill
    #--------------------------------------------------------------------------
    # Перехватывает вызов навыка, извлекает его ID и устанавливает флаг
    # для системы оверлеев, если навык был успешно применен.
    #==========================================================================
    
    if method_defined?(:use_skill) && !method_defined?(:abs_overlay_use_skill_all_original)
      alias_method :abs_overlay_use_skill_all_original, :use_skill

      def use_skill(*args)
        skill_arg = args[0]
        skill_id = 0

        # Определение ID навыка из переданного аргумента
        if defined?(RPG::Skill) && skill_arg.is_a?(RPG::Skill)
          skill_id = skill_arg.id
        elsif skill_arg
          skill_id = skill_arg.to_i
        end

        # Вызов оригинального метода Blizz-ABS
        result = abs_overlay_use_skill_all_original(*args)

        # Установка флага анимации при успешном использовании навыка
        if result != false && skill_id > 0
          if defined?(ABS_OverlayFlags) && ABS_OverlayFlags.respond_to?(:set_skill)
            ABS_OverlayFlags.set_skill(self, skill_id)
          end
        end

        result
      end
    end

  end
end # if defined?(Map_Battler)

  #============================================================================
  
  alias abs_overlay_stop_custom_animation_later stop_custom_animation unless method_defined?(:abs_overlay_stop_custom_animation_later)

  def stop_custom_animation
    # Разблокируем ввод если был заблокирован
    if self == $game_player && self.abs_custom_lock_keys
      ABS_InputLock.unlock
      self.abs_custom_lock_keys = false
    end

    # Вызываем оригинальный метод

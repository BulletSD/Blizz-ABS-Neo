#==============================================================================
# ■ Game_Temp - Хранение счётчика блокировки ввода
#------------------------------------------------------------------------------
# Расширение класса для отслеживания активных блокировок ввода.
#==============================================================================

class Game_Temp
  
  #============================================================================
  # :: Атрибуты
  #============================================================================
  
  # Счётчик активных блокировок ввода (0 = ввод разрешён)
  attr_accessor :abs_input_lock_count

  #============================================================================
  # :: Перехват метода initialize
  #============================================================================
  
  # Защита от повторного алиаса (в Ruby 1.8.1 instance_methods возвращает строки)
  unless instance_methods(false).include?("abs_overlay_inputlock_init")
    alias abs_overlay_inputlock_init initialize
  end

  def initialize
    abs_overlay_inputlock_init
    @abs_input_lock_count = 0
  end

end

#==============================================================================
# ■ ABS Custom Overlay - Система блокировки ввода
#------------------------------------------------------------------------------
# Управление блокировкой ввода во время воспроизведения анимаций.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

#==============================================================================
# ■ ABS_InputLock - Управление счётчиком блокировок
#------------------------------------------------------------------------------
# Модуль для управления вложенными блокировками ввода через счётчик.
#==============================================================================

module ABS_InputLock

  #============================================================================
  # :: Управление счётчиком
  #============================================================================
  
  # Увеличивает счётчик блокировок (поддерживает вложенные lock)
  def self.lock
    return unless $game_temp
    $game_temp.abs_input_lock_count = $game_temp.abs_input_lock_count.to_i + 1
  end

  # Уменьшает счётчик блокировок (не опускается ниже нуля)
  def self.unlock
    return unless $game_temp
    count = $game_temp.abs_input_lock_count.to_i - 1
    $game_temp.abs_input_lock_count = [count, 0].max
  end

  # Проверяет наличие активных блокировок
  def self.locked?
    return false unless $game_temp
    $game_temp.abs_input_lock_count.to_i > 0
  end

end


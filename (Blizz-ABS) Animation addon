# ■ Map_Enemy - Автоматическая настройка оверлеев по имени из БД
#------------------------------------------------------------------------------
# Автоматически подбирает и применяет конфигурацию спрайтов для врагов
# на основе их имени в базе данных RPG Maker.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

if defined?(Map_Enemy)

  class Map_Enemy < Map_Battler

    #==========================================================================
    # :: Перехват метода initialize
    #--------------------------------------------------------------------------
    # Инициализирует врага и запускает автоматическую настройку оверлеев.
    #==========================================================================
    
    unless method_defined?(:abs_overlay_auto_init_name)
      alias abs_overlay_auto_init_name initialize
    end

          def initialize(map_id, event, *args)
      abs_overlay_auto_init_name(map_id, event, *args)

      return unless @battler
      
      setup_overlay_from_database_name

      # ЯДЕРНАЯ ИНИЦИАЛИЗАЦИЯ: обходим любые геттеры/сеттеры Blizz-ABS
      cfg = instance_variable_get(:@abs_sprite_config)
      cfg = {} if cfg.nil? || !cfg.is_a?(Hash)
      instance_variable_set(:@abs_sprite_config, cfg)

      # Запуск анимации появления
      if cfg[:appearance] && !@abs_appearance_playing
        play_custom_animation("appearance", 0, false, false)
        @abs_appearance_playing = true
      end
    end

    #==========================================================================
    # :: Автоматическая настройка оверлеев
    #--------------------------------------------------------------------------
    # Ищет файлы в Graphics/Pictures по имени врага и заполняет конфигурацию.
    #==========================================================================
    
        def setup_overlay_from_database_name
      return unless @battler && @battler.id > 0
      
      enemy_data = $data_enemies[@battler.id]
      return if enemy_data.nil?

      clean_name = enemy_data.name.gsub(/\s+/, "")
      prefix = "#{clean_name}_"

      sizes_to_check = [
        "344x257", "400x299", "120x120", "284x220", "200x136", "195x129",
        "164x164", "160x160", "128x128", "96x96",
        "64x64",   "48x48",   "32x32"
      ]

      found_size = nil
      sizes_to_check.each do |size|
        if FileTest.exist?("Graphics/Pictures/#{prefix}idle_#{size}.png") ||
           FileTest.exist?("Graphics/Pictures/#{prefix}walk_#{size}.png")
          found_size = size
          break
        end
      end

      has_idle = FileTest.exist?("Graphics/Pictures/#{prefix}idle.png")
      has_walk = FileTest.exist?("Graphics/Pictures/#{prefix}walk.png")

      return if !found_size && !has_idle && !has_walk

      # ЯДЕРНАЯ ИНИЦИАЛИЗАЦИЯ
      c = instance_variable_get(:@abs_sprite_config)
      c = {} if c.nil? || !c.is_a?(Hash)
      c[:default_direction] = 4

      if found_size
        size_parts = found_size.split("x")
        c[:frame_width]  = size_parts[0].to_i
        c[:frame_height] = size_parts[1].to_i
      end

      base = found_size ? "#{prefix}%s_#{found_size}" : "#{prefix}%s"

      [:idle, :walk, :run, :dash, :jump, :block, :damage, 
       :attack, :skill, :item, :death, :appearance].each do |state|
        c[state] = base % state.to_s
      end
      c[:skill8] = c[:skill]

      death_candidates = []
      death_candidates << "#{prefix}death_#{found_size}"   if found_size
      death_candidates << "#{prefix}death_#{found_size}_a" if found_size
      death_candidates << "#{prefix}death"
      death_candidates << "#{prefix}death_a"

      death_candidates.each do |test_key|
        if FileTest.exist?("Graphics/Pictures/#{test_key}.png")
          c[:death] = test_key.sub(/_a$/, '')
          break
        end
      end

      anim_speeds = ABS_CustomOverlay::ENEMY_ANIMATION_SPEEDS[clean_name]
      c[:animation_speeds] = anim_speeds if anim_speeds

      # Сохраняем обратно в объект
      instance_variable_set(:@abs_sprite_config, c)

      if self.respond_to?(:src_rect) && self.src_rect
        self.src_rect.set(0, 0, 0, 0)
      end
    end

  end

end # if defined?(Map_Enemy)


  #============================================================================
  # :: Определение размеров кадра
  #============================================================================

  # Автоопределение размера по паттерну в имени файла (например, _64x64)
  def self.detect_frame_size(filename)
    return [FRAME_WIDTH, FRAME_HEIGHT] if filename.nil? || filename.to_s.empty?
    
    if filename.to_s =~ /_(\d+)x(\d+)$/i
      w, h = $1.to_i, $2.to_i
      return [w, h] if w > 0 && h > 0
    end
    
    [FRAME_WIDTH, FRAME_HEIGHT]
  end
  
  # Получение базового размера кадра для персонажа
  def self.get_frame_size(character, config = nil)
    config ||= (character.abs_sprite_config if character.respond_to?(:abs_sprite_config))
    
    if config
      # Приоритет 1: Явно заданные размеры
      w, h = config[:frame_width].to_i, config[:frame_height].to_i
      return [w, h] if w > 0 && h > 0
      
      # Приоритет 2: Автоопределение по имени файла (idle/walk)
      key = config[:idle] || config[:walk]
      if key && !key.to_s.empty?
        detected = detect_frame_size(key)
        return detected if detected[0] != FRAME_WIDTH || detected[1] != FRAME_HEIGHT
      end
    end
    
    [FRAME_WIDTH, FRAME_HEIGHT]
  end
  
  # Получение размера кадра для конкретного ключа анимации
  def self.get_frame_size_for_key(character, key, config = nil)
    config ||= (character.abs_sprite_config if character.respond_to?(:abs_sprite_config))

    # Приоритет 1: Паттерн в имени ключа (поддерживает суффиксы типа _400x299_a)
    if key && !key.to_s.empty? && key.to_s =~ /_(\d+)x(\d+)(?:_[a-zA-Z0-9]+)?$/i
      w, h = $1.to_i, $2.to_i
      return [w, h] if w > 0 && h > 0
    end

    # Приоритет 2: Явные размеры из конфига
    if config
      w, h = config[:frame_width].to_i, config[:frame_height].to_i
      return [w, h] if w > 0 && h > 0
    end

    [FRAME_WIDTH, FRAME_HEIGHT]
  end

  #============================================================================
  # :: Вспомогательные методы
  #============================================================================

  # Безопасная загрузка битмапа (возвращает nil при отсутствии файла)
  def self.bitmap(key)
    return nil if key.nil? || key.to_s.empty?
    begin
      case SOURCE
      when :character
        RPG::Cache.character(key.to_s, 0)
      else
        RPG::Cache.picture(key.to_s)
      end
    rescue
      nil
    end
  end

  # Генерация ключа для сегмента цепочки (base_a, base_b...)
  def self.chain_key(base_key, segment_index)
    return base_key if base_key.nil? || base_key.to_s.empty?
    idx = [segment_index.to_i, 0].max
    "#{base_key}_#{(97 + idx).chr}"
  end

  # Проверка наличия цепочки сегментов
  def self.chain_available?(base_key)
    bitmap(chain_key(base_key, 0)) != nil
  end

  # Подсчет общего количества кадров для файла или цепочки
  def self.total_frames_for_key(character, base_key, config = nil)
    return 1 if base_key.nil? || base_key.to_s.empty?
    config ||= (character.abs_sprite_config if character.respond_to?(:abs_sprite_config))

    total = 0
    if chain_available?(base_key)
      segment = 0
      loop do
        k = chain_key(base_key, segment)
        bmp = bitmap(k)
        break if bmp.nil?
        
        fw, = get_frame_size_for_key(character, k, config)
        fw = 1 if fw < 1
        total += [bmp.width / fw, 1].max
        segment += 1
      end
    else
      bmp = bitmap(base_key)
      return 1 if bmp.nil?
      
      fw, = get_frame_size_for_key(character, base_key, config)
      fw = 1 if fw < 1
      total = [bmp.width / fw, 1].max
    end
    
    total
  end

  # Получение скорости анимации с учетом типа и ID
  def self.get_animation_speed(animation_type, id = nil)
    case animation_type
    when :item
      return ITEM_ANIMATION_SPEEDS[id] if id && ITEM_ANIMATION_SPEEDS[id]
    when :skill
      return SKILL_ANIMATION_SPEEDS[id] if id && SKILL_ANIMATION_SPEEDS[id]
    when :custom
      return CUSTOM_ANIMATION_SPEEDS[id] if id && CUSTOM_ANIMATION_SPEEDS[id]
    end
    
    ANIMATION_SPEEDS[animation_type] || ANIMATION_SPEED
  end

  # Получение количества вариантов атак для персонажа
  def self.get_attack_variants(character)
    return 1 unless USE_RANDOM_ATTACKS
    
    if character.is_a?(Game_Player)
      actor_id = 1
      begin
        actor_id = $game_party.actors[0].id if $game_party && $game_party.actors[0]
      rescue
        actor_id = 1
      end
      return ACTOR_ATTACK_VARIANTS[actor_id] || DEFAULT_ATTACK_VARIANTS
    end
    
    DEFAULT_ATTACK_VARIANTS
  end

  # Выбор корректного ключа атаки с безопасным fallback
  def self.resolve_attack_key(base_key, character)
    return base_key if base_key.nil? || base_key.to_s.empty? || !USE_RANDOM_ATTACKS

    variants = [get_attack_variants(character).to_i, 1].max
    return base_key if variants <= 1

    # Безопасное получение индекса варианта
    variant_index = 0
    if character.respond_to?(:abs_current_attack_variant)
      variant_index = character.abs_current_attack_variant.to_i
    end
    variant_index = variant_index % variants

    candidate = "#{base_key}_#{variant_index}"
    return candidate if bitmap(candidate)
    return base_key if bitmap(base_key)

    # Fallback: поиск первого доступного варианта
    variants.times do |i|
      k = "#{base_key}_#{i}"
      return k if bitmap(k)
    end

    base_key
  end

  # Расчет длительности анимации предмета (в тиках)
  def self.get_item_duration(item_id)
    frames = ITEM_ANIMATION_FRAMES[item_id] || DEFAULT_ITEM_DURATION
    speed = get_animation_speed(:item, item_id)
    speed = 1 if speed.nil? || speed < 1
    frames * speed
  end

  # Расчет длительности анимации навыка (в тиках)
  def self.get_skill_duration(skill_id)
    frames = SKILL_ANIMATION_FRAMES[skill_id] || DEFAULT_SKILL_DURATION
    speed = get_animation_speed(:skill, skill_id)
    speed = 1 if speed.nil? || speed < 1
    frames * speed
  end

end # module ABS_CustomOverlay

#==============================================================================
# ■ Game_Character - Расширение для системы оверлеев
#------------------------------------------------------------------------------
# Добавление атрибутов и методов для управления анимациями Blizz-ABS.
# Совместимо с RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

class Game_Character

  #============================================================================
  # :: Атрибуты (геттеры и сеттеры)
  #============================================================================
  
  # Конфигурация спрайтов и анимаций
  attr_accessor :abs_sprite_config
  
  # Переопределяем геттер для ленивой инициализации (Железобетонная защита от nil)
def abs_sprite_config
  @abs_sprite_config ||= {}
end
  
  # Состояния персонажа
  attr_accessor :abs_jumping, :abs_blocking, :abs_attacking
  
  # Направление и варианты атак
  attr_accessor :abs_last_horizontal_direction, :abs_current_attack_variant
  
  # Предметы и навыки
  attr_accessor :abs_using_item, :abs_current_item_id
  attr_accessor :abs_using_skill, :abs_current_skill_id
  
  # Пользовательские анимации
  attr_accessor :abs_custom_animation, :abs_custom_animation_duration
  attr_accessor :abs_custom_animation_loop, :abs_custom_animation_movement
  attr_accessor :abs_custom_timer_char
  
  # Кэши и очереди (только чтение через геттеры)
  attr_reader :abs_sprite_timers, :abs_cooldowns, :abs_animation_cache
  attr_reader :abs_damage_cache, :abs_state_cache, :abs_active_effects
  attr_reader :abs_projectiles, :abs_animation_queue, :abs_damage_queue

  #============================================================================
  # :: Инициализация атрибутов
  #============================================================================
  
  # Инициализация всех ABS-атрибутов значениями по умолчанию
  # Вызывается при первом обращении к персонажу
  def abs_init_defaults
    # Конфигурация
    @abs_sprite_config ||= {}
    
    # Состояния
    @abs_jumping ||= false
    @abs_blocking ||= false
    @abs_attacking ||= false
    
    # Направление и атаки
    @abs_last_horizontal_direction ||= 6
    @abs_current_attack_variant ||= 0
    
    # Предметы
    @abs_using_item ||= false
    @abs_current_item_id ||= 0
    
    # Навыки
    @abs_using_skill ||= false
    @abs_current_skill_id ||= 0
    
    # Пользовательские анимации
    @abs_custom_animation ||= ""
    @abs_custom_animation_duration ||= 0
    @abs_custom_animation_loop ||= false
    @abs_custom_animation_movement ||= false
    @abs_custom_timer_char ||= 0
    
    # Кэши и очереди
    @abs_sprite_timers ||= {}
    @abs_cooldowns ||= {}
    @abs_animation_cache ||= {}
    @abs_damage_cache ||= {}
    @abs_state_cache ||= {}
    @abs_active_effects ||= []
    @abs_projectiles ||= []
    @abs_animation_queue ||= []
    @abs_damage_queue ||= []
  end

  #============================================================================
  # :: Управление пользовательскими анимациями
  #============================================================================
  
  # Запуск пользовательской анимации
  # animation_name - имя файла анимации
  # duration - длительность в кадрах (по умолчанию 60)
  # anim_loop - зацикливать? (nil = использовать настройку по умолчанию)
  # allow_movement - разрешить движение? (nil = использовать настройку по умолчанию)
  def play_custom_animation(animation_name, duration = 60, anim_loop = nil, allow_movement = nil)
    # Получаем настройки по умолчанию из модуля (если доступен)
    loop_default = false
    movement_default = false
    
    if defined?(ABS_CustomOverlay)
      loop_default = ABS_CustomOverlay::CUSTOM_LOOP
      movement_default = ABS_CustomOverlay::CUSTOM_ALLOW_MOVEMENT
    end
    
    @abs_custom_animation = animation_name
    @abs_custom_animation_duration = duration
    @abs_custom_animation_loop = anim_loop.nil? ? loop_default : anim_loop
    @abs_custom_animation_movement = allow_movement.nil? ? movement_default : allow_movement
  end

  # Остановка пользовательской анимации
  def stop_custom_animation
    @abs_custom_animation = ""
    @abs_custom_animation_duration = 0
    @abs_custom_timer_char = 0
  end

  # Проверка: воспроизводится ли пользовательская анимация?
  def custom_animation_playing?
    @abs_custom_animation.to_s != ""
  end

  #============================================================================
  # :: Геттеры для кэшей (ленивая инициализация)
  #============================================================================
  
  def abs_sprite_timers
    @abs_sprite_timers ||= {}
  end

  def abs_cooldowns
    @abs_cooldowns ||= {}
  end

  def abs_animation_cache
    @abs_animation_cache ||= {}
  end

  def abs_damage_cache
    @abs_damage_cache ||= {}
  end

  def abs_state_cache
    @abs_state_cache ||= {}
  end

  def abs_active_effects
    @abs_active_effects ||= []
  end

  def abs_projectiles
    @abs_projectiles ||= []
  end

  def abs_animation_queue
    @abs_animation_queue ||= []
  end

  def abs_damage_queue
    @abs_damage_queue ||= []
  end

  #============================================================================
  # :: Вспомогательные методы
  #============================================================================
  
  # Кэшированный ключ анимации смерти
  def abs_death_key_cached
    @abs_death_key_cached ||= ""
  end

end # class Game_Character

#==============================================================================
# ■ ABS_OverlayFlags - Безопасная установка флагов состояний
#------------------------------------------------------------------------------
# Модуль для безопасной установки флагов использования предметов и навыков.
# Проверяет наличие методов перед вызовом для предотвращения ошибок.
#==============================================================================

module ABS_OverlayFlags

  #============================================================================
  # :: Установка флага использования предмета
  #============================================================================
  
  # Устанавливает флаг использования предмета для персонажа
  # user - объект персонажа (Game_Character или наследник)
  # item_id - ID предмета из базы данных
  def self.set_item(user, item_id)
    return if user.nil? || item_id.to_i <= 0
    
    if user.respond_to?(:abs_using_item=) && user.respond_to?(:abs_current_item_id=)
      user.abs_using_item = true
      user.abs_current_item_id = item_id
    end
  end

  #============================================================================
  # :: Установка флага использования навыка
  #============================================================================
  
  # Устанавливает флаг использования навыка для персонажа
  # user - объект персонажа (Game_Character или наследник)
  # skill_id - ID навыка из базы данных
  def self.set_skill(user, skill_id)
    return if user.nil? || skill_id.to_i <= 0
    
    if user.respond_to?(:abs_using_skill=) && user.respond_to?(:abs_current_skill_id=)
      user.abs_using_skill = true
      user.abs_current_skill_id = skill_id
    end
  end

end # module ABS_OverlayFlags

#==============================================================================
# ■ Часть 3. Перехватчики методов для Blizz-ABS
#------------------------------------------------------------------------------
# Хуки для интеграции системы оверлеев с Blizz-ABS.
# Перехватывают использование навыков и комбо-атаки врагов.
#==============================================================================

if defined?(Map_Enemy)
  class Map_Enemy

    #==========================================================================
    # :: Перехват метода use_skill
    #--------------------------------------------------------------------------
    # Отслеживает использование навыков врагами для запуска анимаций.
    #==========================================================================
    
    if method_defined?(:use_skill) && !method_defined?(:abs_overlay_use_skill_original)
      alias abs_overlay_use_skill_original use_skill

      def use_skill(*args)
        skill_arg = args[0]
        skill_id = 0

        # Определяем ID навыка из аргумента
        if skill_arg.is_a?(RPG::Skill)
          skill_id = skill_arg.id
        elsif skill_arg.is_a?(Integer)
          skill_id = skill_arg
        end

        # Вызываем оригинальный метод
        result = abs_overlay_use_skill_original(*args)

        # Устанавливаем флаг если навык успешно использован
        if result != false && skill_id > 0
          ABS_OverlayFlags.set_skill(self, skill_id)
        end

        result
      end
    end

    #==========================================================================
    # :: Перехват метода update (отслеживание комбо-навыков)
    #--------------------------------------------------------------------------
    # Отслеживает выполнение комбо-атак для запуска соответствующих анимаций.
    #==========================================================================
    
    if method_defined?(:update) && defined?(COMSkill) && !method_defined?(:abs_overlay_enemy_update_original)
      alias abs_overlay_enemy_update_original update

      def update
        # Безопасно получаем объект комбо
        combo_obj = nil
        begin
          combo_obj = combo if respond_to?(:combo)
        rescue
          combo_obj = nil
        end

        # Обрабатываем комбо-команды
        if combo_obj
          begin
            action_id = combo_obj.aid rescue nil
            commands = combo_obj.commands rescue nil

            if commands && action_id
              current_step = commands[action_id] rescue nil

              if current_step && current_step.respond_to?(:each)
                current_step.each do |command|
                  next unless command.respond_to?(:[])

                  # Проверяем, является ли команда навыком
                  if command[0] == COMSkill
                    skill_id = command[1].to_i

                    if skill_id > 0
                      # Проверяем, не установлен ли уже этот навык
                      skill_active = respond_to?(:abs_using_skill) && abs_using_skill
                      skill_match = respond_to?(:abs_current_skill_id) && abs_current_skill_id == skill_id

                      # Устанавливаем флаг если навык еще не активен
                      ABS_OverlayFlags.set_skill(self, skill_id) unless (skill_active && skill_match)
                    end

                    break # Обрабатываем только первый найденный навык
                  end
                end
              end
            end
          rescue StandardError
            # Игнорируем ошибки обработки комбо, но не системные исключения
          end
        end

        # Вызываем оригинальный update
        abs_overlay_enemy_update_original
      end
    end

  end
end # if defined?(Map_Enemy)

#==============================================================================
# ■ Перехват метода hotkey_execute для BlizzABS
#------------------------------------------------------------------------------
# Отслеживает использование хоткеев для запуска анимаций предметов и навыков.
# Совместимость: Ruby 1.8.1 / RGSS (RPG Maker XP)
#==============================================================================

if defined?(BlizzABS) && defined?(Game_System)

  class Game_System

    #==========================================================================
    # :: Перехват метода hotkey_execute
    #--------------------------------------------------------------------------
    # Перехватывает выполнение хоткеев для установки флагов использования
    # предметов и навыков игроком.
    #==========================================================================
    
    if method_defined?('hotkey_execute') && !method_defined?('abs_overlay_hotkey_execute_original')
      alias abs_overlay_hotkey_execute_original hotkey_execute

      def hotkey_execute(index)
        begin
          # Получаем хоткей по индексу
          hotkey = @hotkeys[index] rescue nil

          if hotkey.is_a?(Array)
            type = hotkey[0]
            id = hotkey[1].to_i

            # Проверяем валидность данных
            item_valid = ($data_items[id] != nil rescue false)
            skill_valid = ($data_skills[id] != nil rescue false)

            # Определяем тип и устанавливаем соответствующий флаг
            if type == 1 && item_valid
              # Тип 1 - предмет
              ABS_OverlayFlags.set_item($game_player, id)
              
            elsif (type == 0 || type == 2) && skill_valid
              # Тип 0 или 2 - навык
              ABS_OverlayFlags.set_skill($game_player, id)
              
            else
              # Неизвестный тип - определяем по наличию данных (приоритет: навык)
              if skill_valid
                ABS_OverlayFlags.set_skill($game_player, id)
              elsif item_valid
                ABS_OverlayFlags.set_item($game_player, id)
              end
            end
          end

        rescue Exception => e
          # Логируем ошибки для отладки
          p "[ABS_Overlay] hotkey_execute error: #{e.message}"
        end

        # Вызываем оригинальный метод
        abs_overlay_hotkey_execute_original(index)
      end

    end

  end # class Game_System

end # if defined?(BlizzABS)

#==============================================================================
# ■ Control_Sprite_Character - Рендеринг оверлей-анимаций
#------------------------------------------------------------------------------
# Расширение класса спрайта персонажа для отрисовки дополнительных анимаций.
# Совместимо с RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

if defined?(Control_Sprite_Character)
  class Control_Sprite_Character

    #==========================================================================
    # :: Перехват базовых методов (update, dispose)
    #==========================================================================
    
    if !method_defined?(:abs_overlay_update_blizzabs_later)
      alias abs_overlay_update_blizzabs_later update
    end
    
    def update
      abs_overlay_update_blizzabs_later
      abs_overlay_update
      abs_overlay_hide_original
    end

    if !method_defined?(:abs_overlay_dispose_blizzabs_later)
      alias abs_overlay_dispose_blizzabs_later dispose
    end
    
    def dispose
      abs_overlay_dispose_overlay
      abs_overlay_dispose_blizzabs_later
    end
    #==========================================================================
    # :: Определение ключа состояния (abs_fetch_state_key)
    #--------------------------------------------------------------------------
    # Возвращает [key, use_mirror] для заданного состояния и направления.
    #==========================================================================
    
    def abs_fetch_state_key(state_sym, direction, sprite_direction, config)
      key = nil
      use_mirror = false

      default_dir  = config[:default_direction] || ABS_CustomOverlay::DEFAULT_DIRECTION
      mirror_pairs = config[:mirror_pairs]       || ABS_CustomOverlay::MIRROR_PAIRS

      # 1. Попытка получить ключ для текущего направления
      case direction
      when 2 then key = config[:"#{state_sym}_down"]
      when 4 then key = config[:"#{state_sym}_left"]
      when 6 then key = config[:"#{state_sym}_right"]
      when 8 then key = config[:"#{state_sym}_up"]
      end

      # 2. Фоллбек на базовый ключ (без направления)
      if (key.nil? || key == '') && config[state_sym]
        key = config[state_sym]
        if ABS_CustomOverlay::AUTO_MIRROR
          mirror_dir = mirror_pairs[sprite_direction]
          use_mirror = (mirror_dir == default_dir)
        end
      end

      # 3. Попытка зеркалирования для недостающих направлений
      if (key.nil? || key == '') && ABS_CustomOverlay::AUTO_MIRROR
        mirror_dir = mirror_pairs[direction]
        if mirror_dir
          case mirror_dir
          when 2 then key = config[:"#{state_sym}_down"]
          when 4 then key = config[:"#{state_sym}_left"]
          when 6 then key = config[:"#{state_sym}_right"]
          when 8 then key = config[:"#{state_sym}_up"]
          end
          use_mirror = true if key && key != ''
        end
      end

      # 4. Фоллбек для специфичных навыков/предметов на базовые анимации
      if (key.nil? || key == '')
        name = state_sym.to_s
        if name =~ /^skill\d+$/ && config[:skill] && config[:skill] != ''
          key = config[:skill]
          if ABS_CustomOverlay::AUTO_MIRROR
            mirror_dir = mirror_pairs[sprite_direction]
            use_mirror = (mirror_dir == default_dir) if mirror_dir
          end
        elsif name =~ /^item\d+$/ && config[:item] && config[:item] != ''
          key = config[:item]
          if ABS_CustomOverlay::AUTO_MIRROR
            mirror_dir = mirror_pairs[sprite_direction]
            use_mirror = (mirror_dir == default_dir) if mirror_dir
          end
        end
      end

      [key, use_mirror]
    end

    #==========================================================================
    # :: Главное обновление оверлея (abs_overlay_update)
    #==========================================================================
    
    def abs_overlay_update
      base = @sprite
      
      # Проверка базового спрайта
      if base.nil? || base.disposed?
        abs_overlay_dispose_overlay
        return
      end

      # Проверка на труп (окончание анимации смерти)
      if @character.character_name.to_s =~ /_crp$/i
        cfg = @character.abs_sprite_config rescue nil
        unless (cfg && cfg[:death] && !@abs_death_animation_complete)
          abs_overlay_dispose_overlay
          return
        end
      end

      return unless @character

      config = @character.abs_sprite_config
      if config.nil? || config.empty?
        abs_overlay_dispose_overlay
        return
      end

      # ── Определение движения ──────────────────────────────────────────────
      real_dx = 0
      real_dx = @character.real_x - @abs_last_real_x if @abs_last_real_x

      is_moving = @character.respond_to?(:moving?) ? @character.moving? : false
      if !is_moving && @character.respond_to?(:real_x)
        if real_dx != 0 || (@character.real_y != (@abs_last_real_y || @character.real_y))
          is_moving = true
        end
      end

      @abs_last_real_x = @character.real_x
      @abs_last_real_y = @character.real_y

      # ── Состояние смерти ──────────────────────────────────────────────────
      is_dying = (@abs_death_started && !@abs_death_animation_complete)

      if @character.respond_to?(:battler)
        b = @character.battler rescue nil
        if b && b.respond_to?(:hp) && b.hp <= 0
          cname = @character.character_name.to_s
          if @abs_death_animation_complete
            is_dying = false
          elsif @abs_death_started
            is_dying = true
          else
            is_dying = true
            @abs_death_frame_reset = true
            @abs_death_started = true
            @abs_death_original_name = (cname =~ /_crp$/ ? nil : cname)
            @abs_death_key_cached = config[:death]
          end
        end
      end

      # ── Рывок (Dash) ──────────────────────────────────────────────────────
      is_dashing = false
      if is_moving
        case ABS_CustomOverlay::DASH_DETECTION
        when :speed
          speed = @character.move_speed rescue 4
          is_dashing = (speed >= ABS_CustomOverlay::DASH_SPEED_THRESHOLD)
        when :button
          is_dashing = Input.press?(ABS_CustomOverlay::DASH_BUTTON) if @character.is_a?(Game_Player)
        when :both
          speed = @character.move_speed rescue 4
          speed_check = (speed >= ABS_CustomOverlay::DASH_SPEED_THRESHOLD)
          button_check = (@character.is_a?(Game_Player) && Input.press?(ABS_CustomOverlay::DASH_BUTTON))
          is_dashing = (speed_check && button_check)
        end
      end

      # ── Прыжок (Jump) ─────────────────────────────────────────────────────
      is_jumping = false
      case ABS_CustomOverlay::JUMP_DETECTION
      when :button
        is_jumping = Input.press?(ABS_CustomOverlay::JUMP_BUTTON) if @character.is_a?(Game_Player)
      when :trigger
        if @character.is_a?(Game_Player)
          if Input.trigger?(ABS_CustomOverlay::JUMP_BUTTON)
            @abs_jump_active = true
            @abs_jump_frame_reset = true
          end
          if @abs_jump_active && !ABS_CustomOverlay::JUMP_LOOP
            if @abs_overlay_total_frames && @abs_overlay_total_frames > 0
              @abs_jump_active = false if @abs_overlay_current_frame >= (@abs_overlay_total_frames - 1)
            end
          end
          is_jumping = !!@abs_jump_active
        end
      when :jumping
        if @character.respond_to?(:jumping)
          is_jumping = @character.jumping
        elsif @character.respond_to?(:abs_jumping)
          is_jumping = @character.abs_jumping
        end
      end

      # ── Блок (Block) ──────────────────────────────────────────────────────
      is_blocking = false
      if @character.is_a?(Game_Player)
        case ABS_CustomOverlay::BLOCK_DETECTION
        when :button
          is_blocking = Input.press?(ABS_CustomOverlay::BLOCK_BUTTON)
        when :trigger
          if Input.trigger?(ABS_CustomOverlay::BLOCK_BUTTON)
            @abs_block_active = true
            @abs_block_frame_reset = true
          end
          if @abs_block_active && !ABS_CustomOverlay::BLOCK_LOOP
            if @abs_overlay_total_frames && @abs_overlay_total_frames > 0
              @abs_block_active = false if @abs_overlay_current_frame >= (@abs_overlay_total_frames - 1)
            end
          end
          is_blocking = !!@abs_block_active
        when :blocking
          is_blocking = @character.respond_to?(:blocking) ? @character.blocking : @character.abs_blocking rescue false
        end
      else
        if @character.respond_to?(:defending) && @character.defending
          is_blocking = true
        elsif @character.respond_to?(:in_action) && @character.in_action > 0
          if @character.respond_to?(:last_action) && @character.last_action.is_a?(Array)
            if @character.last_action[0] == "defend"
              is_blocking = true
              penalty = @character.respond_to?(:defend_penalty) ? @character.defend_penalty : 0
              @abs_block_frame_reset = true if @character.in_action == penalty
            end
          end
        end
      end
      is_blocking = false if is_blocking && !ABS_CustomOverlay::BLOCK_ALLOW_MOVEMENT && is_moving

      # ── Атака (Attack) ────────────────────────────────────────────────────
      is_attacking = false
      if @character.is_a?(Game_Player)
        case ABS_CustomOverlay::ATTACK_DETECTION
        when :button
          is_attacking = Input.press?(ABS_CustomOverlay::ATTACK_BUTTON)
        when :trigger
          @abs_attack_timer ||= 0
          @abs_attack_timer -= 1 if @abs_attack_timer > 0
          if Input.trigger?(ABS_CustomOverlay::ATTACK_BUTTON) && @abs_attack_timer <= 0
            @abs_attack_frame_reset = true
            if ABS_CustomOverlay::USE_RANDOM_ATTACKS
              variants = ABS_CustomOverlay.get_attack_variants(@character)
              @character.abs_current_attack_variant = rand(variants)
            else
              @character.abs_current_attack_variant = 0
            end
            attack_speed = ABS_CustomOverlay.get_animation_speed(:attack)
            @abs_attack_timer = 16 * attack_speed
          end
          is_attacking = (@abs_attack_timer > 0)
        when :attacking
          is_attacking = (@character.respond_to?(:attacking) && @character.attacking)
        end
      else
        if @character.respond_to?(:in_action) && @character.in_action > 0
          if @character.respond_to?(:last_action) && @character.last_action.is_a?(Array)
            if @character.last_action[0] == "attack"
              is_attacking = true
              penalty = @character.respond_to?(:attack_penalty) ? @character.attack_penalty : 0
              if @character.in_action == penalty
                @abs_attack_frame_reset = true
                if ABS_CustomOverlay::USE_RANDOM_ATTACKS
                  variants = ABS_CustomOverlay.get_attack_variants(@character)
                  @character.abs_current_attack_variant = rand(variants)
                end
              end
            end
          end
        end
      end
      is_attacking = false if is_attacking && !ABS_CustomOverlay::ATTACK_ALLOW_MOVEMENT && is_moving

      # ── Использование предмета ────────────────────────────────────────────
      is_using_item = false
      current_item_id = 0
      if @character.abs_using_item
        @abs_item_timer ||= 0
        if @abs_item_timer <= 0
          current_item_id = @character.abs_current_item_id
          @abs_item_frame_reset = true
          @abs_item_timer = ABS_CustomOverlay.get_item_duration(current_item_id)
        end
        if @abs_item_timer > 0
          @abs_item_timer -= 1
          is_using_item = true
          current_item_id = @character.abs_current_item_id
          if @abs_item_timer <= 0
            @character.abs_using_item = false
            @character.abs_current_item_id = 0
          end
        end
      end
      is_using_item = false if is_using_item && !ABS_CustomOverlay::ITEM_ALLOW_MOVEMENT && is_moving

      # ── Использование навыка ──────────────────────────────────────────────
      is_using_skill = false
      current_skill_id = 0
      if @character.abs_using_skill
        @abs_skill_timer ||= 0
        if @abs_skill_timer <= 0
          current_skill_id = @character.abs_current_skill_id
          @abs_skill_frame_reset = true
          @abs_skill_timer = ABS_CustomOverlay.get_skill_duration(current_skill_id)
        end
        if @abs_skill_timer > 0
          @abs_skill_timer -= 1
          is_using_skill = true
          current_skill_id = @character.abs_current_skill_id
          if @abs_skill_timer <= 0
            @character.abs_using_skill = false
            @character.abs_current_skill_id = 0
          end
        end
      end
      is_using_skill = false if is_using_skill && !ABS_CustomOverlay::SKILL_ALLOW_MOVEMENT && is_moving

      # ── Пользовательская анимация ─────────────────────────────────────────
      is_custom_animation = false
      current_custom_name = nil
      if @character.custom_animation_playing?
        @character.abs_custom_timer_char ||= 0
        if @character.abs_custom_timer_char <= 0
          current_custom_name = @character.abs_custom_animation
          @abs_custom_frame_reset = true
          dur = @character.abs_custom_animation_duration rescue nil
          @character.abs_custom_timer_char = (dur && dur > 0) ? dur : 1
        end
        if @character.abs_custom_timer_char > 0
          @character.abs_custom_timer_char -= 1
          is_custom_animation = true
          current_custom_name = @character.abs_custom_animation
          if @character.abs_custom_timer_char <= 0 && !@character.abs_custom_animation_loop
            @character.stop_custom_animation
            @character.instance_variable_set(:@abs_appearance_playing, false)
          end
        end
      else
        @character.abs_custom_timer_char = 0
      end
      is_custom_animation = false if is_custom_animation && !@character.abs_custom_animation_movement && is_moving

      # ── Направление ───────────────────────────────────────────────────────
      direction = @character.direction rescue 6
      if is_moving
        direction = 6 if real_dx > 0
        direction = 4 if real_dx < 0
      end
      if is_attacking && @character.is_a?(Map_Enemy) && $game_player
        p_x, e_x = $game_player.real_x, @character.real_x
        direction = (p_x > e_x) ? 6 : ((p_x < e_x) ? 4 : direction)
      end

      @character.abs_last_horizontal_direction = direction if (direction == 4 || direction == 6)
      
      sprite_direction = direction
      sprite_direction = @character.abs_last_horizontal_direction if (direction == 2 || direction == 8)

      # ── Приоритеты анимаций ───────────────────────────────────────────────
      key = nil
      animation_type = nil
      use_mirror = false
      force_no_loop = false

      @abs_locked_action_key ||= nil
      @abs_locked_action_type ||= nil

      # Вспомогательная лямбда для выбора действия
      pick_action = lambda do |base_sym, type_sym, loop_flag|
        k, m = abs_fetch_state_key(base_sym, direction, sprite_direction, config)
        if k && k != ''
          key = k
          use_mirror = m
          animation_type = type_sym
          force_no_loop = !loop_flag
          true
        else
          false
        end
      end

      # Смерть (наивысший приоритет)
      if is_dying
        k, m = abs_fetch_state_key(:death, direction, sprite_direction, config)
        if k && k != ''
          @abs_locked_action_key = nil
          @abs_locked_action_type = nil
          key = k
          use_mirror = m
          animation_type = :death
          force_no_loop = true
        else
          @abs_death_animation_complete = true
        end
      end

      # Приоритет 5
      if (key.nil? || key == '') && is_custom_animation && ABS_CustomOverlay::CUSTOM_PRIORITY >= 5
        k, m = abs_fetch_state_key(current_custom_name.to_sym, direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :custom
          force_no_loop = !(@character.abs_custom_animation_loop rescue false)
        end
      end

      # Приоритет 4
      if (key.nil? || key == '') && is_using_item && ABS_CustomOverlay::ITEM_PRIORITY >= 4
        pick_action.call(:"item#{current_item_id}", :item, ABS_CustomOverlay::ITEM_LOOP)
      end
      if (key.nil? || key == '') && is_using_skill && ABS_CustomOverlay::SKILL_PRIORITY >= 4
        pick_action.call(:"skill#{current_skill_id}", :skill, ABS_CustomOverlay::SKILL_LOOP)
      end
      if (key.nil? || key == '') && is_custom_animation && ABS_CustomOverlay::CUSTOM_PRIORITY >= 4
        k, m = abs_fetch_state_key(current_custom_name.to_sym, direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :custom
          force_no_loop = !(@character.abs_custom_animation_loop rescue false)
        end
      end
      if (key.nil? || key == '') && is_attacking && ABS_CustomOverlay::ATTACK_PRIORITY >= 4
        k, m = abs_fetch_state_key(:attack, direction, sprite_direction, config)
        if k && k != ''
          k = ABS_CustomOverlay.resolve_attack_key(k, @character)
          key = k; use_mirror = m; animation_type = :attack
          force_no_loop = !ABS_CustomOverlay::ATTACK_LOOP
        end
      end

      # Прыжок
      if (key.nil? || key == '') && is_jumping && ABS_CustomOverlay::JUMP_PRIORITY
        k, m = abs_fetch_state_key(:jump, direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :jump
          force_no_loop = !ABS_CustomOverlay::JUMP_LOOP
        end
      end

      # Приоритет 3
      if (key.nil? || key == '') && is_using_item && ABS_CustomOverlay::ITEM_PRIORITY >= 3
        pick_action.call(:"item#{current_item_id}", :item, ABS_CustomOverlay::ITEM_LOOP)
      end
      if (key.nil? || key == '') && is_using_skill && ABS_CustomOverlay::SKILL_PRIORITY >= 3
        pick_action.call(:"skill#{current_skill_id}", :skill, ABS_CustomOverlay::SKILL_LOOP)
      end
      if (key.nil? || key == '') && is_custom_animation && ABS_CustomOverlay::CUSTOM_PRIORITY >= 3
        k, m = abs_fetch_state_key(current_custom_name.to_sym, direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :custom
          force_no_loop = !(@character.abs_custom_animation_loop rescue false)
        end
      end
      if (key.nil? || key == '') && is_attacking && ABS_CustomOverlay::ATTACK_PRIORITY >= 3
        k, m = abs_fetch_state_key(:attack, direction, sprite_direction, config)
        if k && k != ''
          k = ABS_CustomOverlay.resolve_attack_key(k, @character)
          key = k; use_mirror = m; animation_type = :attack
          force_no_loop = !ABS_CustomOverlay::ATTACK_LOOP
        end
      end

      # Блок (приоритет 2)
      if (key.nil? || key == '') && is_blocking && is_moving && ABS_CustomOverlay::BLOCK_PRIORITY >= 2
        pick_action.call(:block, :block, ABS_CustomOverlay::BLOCK_LOOP)
      end
      if (key.nil? || key == '') && is_blocking && !is_moving && ABS_CustomOverlay::BLOCK_PRIORITY >= 2
        k, m = abs_fetch_state_key(:block_idle, direction, sprite_direction, config)
        k, m = abs_fetch_state_key(:block, direction, sprite_direction, config) if (k.nil? || k == '')
        if k && k != ''
          key = k; use_mirror = m; animation_type = :block_idle
          force_no_loop = !ABS_CustomOverlay::BLOCK_LOOP
        end
      end

      # Приоритет 2
      if (key.nil? || key == '') && is_using_item && ABS_CustomOverlay::ITEM_PRIORITY >= 2
        pick_action.call(:"item#{current_item_id}", :item, ABS_CustomOverlay::ITEM_LOOP)
      end
      if (key.nil? || key == '') && is_using_skill && ABS_CustomOverlay::SKILL_PRIORITY >= 2
        pick_action.call(:"skill#{current_skill_id}", :skill, ABS_CustomOverlay::SKILL_LOOP)
      end
      if (key.nil? || key == '') && is_custom_animation && ABS_CustomOverlay::CUSTOM_PRIORITY >= 2
        k, m = abs_fetch_state_key(current_custom_name.to_sym, direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :custom
          force_no_loop = !(@character.abs_custom_animation_loop rescue false)
        end
      end
      if (key.nil? || key == '') && is_attacking && ABS_CustomOverlay::ATTACK_PRIORITY >= 2
        k, m = abs_fetch_state_key(:attack, direction, sprite_direction, config)
        if k && k != ''
          k = ABS_CustomOverlay.resolve_attack_key(k, @character)
          key = k; use_mirror = m; animation_type = :attack
          force_no_loop = !ABS_CustomOverlay::ATTACK_LOOP
        end
      end

      # Бег / Рывок
      if (key.nil? || key == '') && is_moving && is_dashing
        k, m = abs_fetch_state_key(:run, direction, sprite_direction, config)
        if k.nil? || k == ''
          k, m = abs_fetch_state_key(:dash, direction, sprite_direction, config)
          animation_type = :dash if k && k != ''
        else
          animation_type = :run if k && k != ''
        end
        key = k; use_mirror = m if k && k != ''
      end

      # Блок (приоритет 1)
      if (key.nil? || key == '') && is_blocking && is_moving && ABS_CustomOverlay::BLOCK_PRIORITY >= 1
        pick_action.call(:block, :block, ABS_CustomOverlay::BLOCK_LOOP)
      end

      # Приоритет 1
      if (key.nil? || key == '') && is_using_item && ABS_CustomOverlay::ITEM_PRIORITY >= 1
        pick_action.call(:"item#{current_item_id}", :item, ABS_CustomOverlay::ITEM_LOOP)
      end
      if (key.nil? || key == '') && is_using_skill && ABS_CustomOverlay::SKILL_PRIORITY >= 1
        pick_action.call(:"skill#{current_skill_id}", :skill, ABS_CustomOverlay::SKILL_LOOP)
      end
      if (key.nil? || key == '') && is_custom_animation && ABS_CustomOverlay::CUSTOM_PRIORITY >= 1
        k, m = abs_fetch_state_key(current_custom_name.to_sym, direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :custom
          force_no_loop = !(@character.abs_custom_animation_loop rescue false)
        end
      end
      if (key.nil? || key == '') && is_attacking && ABS_CustomOverlay::ATTACK_PRIORITY >= 1
        k, m = abs_fetch_state_key(:attack, direction, sprite_direction, config)
        if k && k != ''
          k = ABS_CustomOverlay.resolve_attack_key(k, @character)
          key = k; use_mirror = m; animation_type = :attack
          force_no_loop = !ABS_CustomOverlay::ATTACK_LOOP
        end
      end

      # Ходьба
      if (key.nil? || key == '') && is_moving
        unless @character.instance_variable_get(:@abs_appearance_playing)
          k, m = abs_fetch_state_key(:walk, direction, sprite_direction, config)
          if k && k != ''
            key = k; use_mirror = m; animation_type = :walk
          end
        end
      end

      # Блок стоя (низкий приоритет)
      if (key.nil? || key == '') && is_blocking && !is_moving
        unless @character.instance_variable_get(:@abs_appearance_playing)
          k, m = abs_fetch_state_key(:block_idle, direction, sprite_direction, config)
          k, m = abs_fetch_state_key(:block, direction, sprite_direction, config) if (k.nil? || k == '')
          if k && k != ''
            key = k; use_mirror = m; animation_type = :block_idle
            force_no_loop = !ABS_CustomOverlay::BLOCK_LOOP
          end
        end
      end

      # Приоритет 0 (без движения)
      if (key.nil? || key == '') && is_using_item && !is_moving
        k, m = abs_fetch_state_key(:"item#{current_item_id}", direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :item
          force_no_loop = !ABS_CustomOverlay::ITEM_LOOP
        end
      end
      if (key.nil? || key == '') && is_using_skill && !is_moving
        k, m = abs_fetch_state_key(:"skill#{current_skill_id}", direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :skill
          force_no_loop = !ABS_CustomOverlay::SKILL_LOOP
        end
      end
      if (key.nil? || key == '') && is_custom_animation && !is_moving
        k, m = abs_fetch_state_key(current_custom_name.to_sym, direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :custom
          force_no_loop = !(@character.abs_custom_animation_loop rescue false)
        end
      end
      if (key.nil? || key == '') && is_attacking && !is_moving
        k, m = abs_fetch_state_key(:attack, direction, sprite_direction, config)
        if k && k != ''
          k = ABS_CustomOverlay.resolve_attack_key(k, @character)
          key = k; use_mirror = m; animation_type = :attack
          force_no_loop = !ABS_CustomOverlay::ATTACK_LOOP
        end
      end

      # Ожидание (Idle)
      if (key.nil? || key == '') && !is_moving
        k, m = abs_fetch_state_key(:idle, direction, sprite_direction, config)
        if k && k != ''
          key = k; use_mirror = m; animation_type = :idle
        end
      end

      # Продолжение зафиксированного non-loop действия
      if !is_dying && @abs_locked_action_key && @abs_locked_action_key != ''
        key = @abs_locked_action_key
        animation_type = @abs_locked_action_type
        force_no_loop = true
      end

      if key.nil? || key == ''
        abs_overlay_dispose_overlay
        return
      end

      # ── Автоцепочка сегментов анимации ────────────────────────────────────
      @abs_chain_base_key ||= nil
      @abs_chain_segment  ||= 0
      @abs_chain_enabled  ||= false

      should_reinit_chain =
        (@abs_chain_base_key != key) ||
        @abs_death_frame_reset ||
        (animation_type == :jump       && @abs_jump_frame_reset)   ||
        (animation_type == :block      && @abs_block_frame_reset)  ||
        (animation_type == :block_idle && @abs_block_frame_reset)  ||
        (animation_type == :attack     && @abs_attack_frame_reset) ||
        (animation_type == :item       && @abs_item_frame_reset)   ||
        (animation_type == :skill      && @abs_skill_frame_reset)  ||
        (animation_type == :custom     && @abs_custom_frame_reset)
        
      if should_reinit_chain
        @abs_chain_base_key = key
        @abs_chain_segment  = 0
        @abs_chain_enabled  = ABS_CustomOverlay.chain_available?(key)
      end
      
      # Синхронизация skill-таймера с длиной цепочки
      if should_reinit_chain && animation_type == :skill && @abs_chain_enabled
        total = ABS_CustomOverlay.total_frames_for_key(@character, key, config)
        spd   = ABS_CustomOverlay.get_animation_speed(:skill, current_skill_id)
        spd   = 1 if spd.nil? || spd < 1
        @abs_skill_timer = total * spd
      end

      if !@abs_locked_action_key && force_no_loop && @abs_chain_enabled && animation_type != :death
        @abs_locked_action_key  = key
        @abs_locked_action_type = animation_type
      end
      
      current_draw_key = @abs_chain_enabled ? ABS_CustomOverlay.chain_key(@abs_chain_base_key, @abs_chain_segment) : key

      bmp = ABS_CustomOverlay.bitmap(current_draw_key)
      if bmp.nil?
        abs_overlay_dispose_overlay
        return
      end

      # ── Инициализация и обновление спрайта ────────────────────────────────
      if @abs_overlay_sprite.nil? || @abs_overlay_sprite.disposed?
        @abs_overlay_sprite        = Sprite.new(@viewport)
        @abs_overlay_frame_counter = 0
        @abs_overlay_current_frame = 0
        @abs_overlay_total_frames  = 1
      end

      key_changed =
        @abs_overlay_key_cached != current_draw_key ||
        @abs_jump_frame_reset   || @abs_block_frame_reset  || @abs_attack_frame_reset ||
        @abs_item_frame_reset   || @abs_skill_frame_reset  || @abs_custom_frame_reset ||
        @abs_death_frame_reset

      if key_changed
        @abs_overlay_sprite.bitmap  = bmp
        @abs_overlay_key_cached     = current_draw_key
        @abs_overlay_frame_counter  = 0
        @abs_overlay_current_frame  = 0

        @abs_jump_frame_reset   = false
        @abs_block_frame_reset  = false
        @abs_attack_frame_reset = false
        @abs_item_frame_reset   = false
        @abs_skill_frame_reset  = false
        @abs_custom_frame_reset = false
        @abs_death_frame_reset  = false

        fw, fh = ABS_CustomOverlay.get_frame_size_for_key(@character, current_draw_key, config)
        fw = 1 if fw <= 0
        @abs_overlay_total_frames = bmp.width / fw
        @abs_overlay_total_frames = 1 if @abs_overlay_total_frames <= 0
      end

      # ── Скорость анимации ─────────────────────────────────────────────────
      current_speed = ABS_CustomOverlay::ANIMATION_SPEED
      if config[:animation_speeds] && config[:animation_speeds][animation_type]
        current_speed = config[:animation_speeds][animation_type]
      elsif animation_type == :item
        current_speed = ABS_CustomOverlay.get_animation_speed(:item, current_item_id)
      elsif animation_type == :skill
        current_speed = ABS_CustomOverlay.get_animation_speed(:skill, current_skill_id)
      elsif animation_type == :custom
        current_speed = ABS_CustomOverlay.get_animation_speed(:custom, current_custom_name)
      elsif animation_type
        current_speed = ABS_CustomOverlay.get_animation_speed(animation_type)
      end
      current_speed = 1 if current_speed.nil? || current_speed < 1

      # ── Продвижение кадра ─────────────────────────────────────────────────
      @abs_overlay_frame_counter += 1

      if @abs_overlay_frame_counter >= current_speed
        @abs_overlay_frame_counter = 0

        if force_no_loop
          if @abs_overlay_current_frame < (@abs_overlay_total_frames - 1)
            @abs_overlay_current_frame += 1
          else
            if @abs_chain_enabled
              next_segment = @abs_chain_segment + 1
              next_key     = ABS_CustomOverlay.chain_key(@abs_chain_base_key, next_segment)
              if ABS_CustomOverlay.bitmap(next_key)
                @abs_chain_segment = next_segment
                @abs_overlay_current_frame = 0
                @abs_overlay_frame_counter = 0
                @abs_overlay_key_cached    = nil
              else
                if animation_type == :death
                  @abs_death_animation_complete = true
                  @character.instance_variable_set(:@abs_death_animation_complete, true) if @character
                elsif @abs_locked_action_key == @abs_chain_base_key
                  @abs_chain_base_key = @abs_locked_action_key
                  @abs_locked_action_key  = nil
                  @abs_locked_action_type = nil
                end
              end
            else
              if animation_type == :death
                @abs_death_animation_complete = true
                @character.instance_variable_set(:@abs_death_animation_complete, true) if @character
              elsif @abs_locked_action_key
                @abs_chain_base_key = @abs_locked_action_key
                @abs_locked_action_key  = nil
                @abs_locked_action_type = nil
              end
            end
          end
        else
          if @abs_overlay_current_frame < (@abs_overlay_total_frames - 1)
            @abs_overlay_current_frame += 1
          else
            if @abs_chain_enabled
              next_segment = @abs_chain_segment + 1
              next_key     = ABS_CustomOverlay.chain_key(@abs_chain_base_key, next_segment)
              @abs_chain_segment = ABS_CustomOverlay.bitmap(next_key) ? next_segment : 0
              @abs_overlay_current_frame = 0
              @abs_overlay_frame_counter = 0
              @abs_overlay_key_cached    = nil
            else
              @abs_overlay_current_frame = 0
            end
          end
        end
      end

      # ── Отрисовка ─────────────────────────────────────────────────────────
      fw, fh = ABS_CustomOverlay.get_frame_size_for_key(@character, current_draw_key, config)
      fw = 1 if fw <= 0
      fh = 1 if fh <= 0

      frame = @abs_overlay_current_frame

      if ABS_CustomOverlay::STRIP_MODE == :directional
        row = case direction
              when 2 then 0
              when 4 then 1
              when 6 then 2
              else        3
              end
        @abs_overlay_sprite.src_rect.set(frame * fw, row * fh, fw, fh)
      else
        @abs_overlay_sprite.src_rect.set(frame * fw, 0, fw, fh)
      end

      @abs_overlay_sprite.ox = fw / 2
      @abs_overlay_sprite.oy = fh / 2

      @abs_overlay_sprite.x = base.x + ABS_CustomOverlay::OFFSET_X
      @abs_overlay_sprite.y = base.y + ABS_CustomOverlay::OFFSET_Y
      #@abs_overlay_sprite.z = (base.z rescue 0) + ABS_CustomOverlay::Z_PLUS

      z_plus = (config[:z_plus] || ABS_CustomOverlay::Z_PLUS)
      @abs_overlay_sprite.z = (base.z rescue 0) + z_plus

      @abs_overlay_sprite.mirror = use_mirror if @abs_overlay_sprite.respond_to?(:mirror=)

      @abs_overlay_sprite.visible    = true
      @abs_overlay_sprite.opacity    = 255
      @abs_overlay_sprite.blend_type = 0
    end

    #==========================================================================
    # :: Скрытие оригинального спрайта
    #==========================================================================

    def abs_overlay_hide_original
      return unless ABS_CustomOverlay::HIDE_ORIGINAL_SPRITE

      base = @sprite
      return if base.nil? || base.disposed?
      return unless @character

      cname = @character.character_name.to_s
      if cname =~ /_crp$/i
        cfg = @character.abs_sprite_config rescue nil
        return unless (cfg && cfg[:death] && !@abs_death_animation_complete)
      end

      config = @character.abs_sprite_config
      return if config.nil? || config.empty?
      
      # Скрываем базовый спрайт только если оверлей реально отрисовывается
      return if @abs_overlay_sprite.nil? || (@abs_overlay_sprite.disposed? rescue true)


      base.src_rect.set(0, 0, 0, 0) if base.respond_to?(:src_rect) && base.src_rect
      end

    #==========================================================================
    # :: Очистка ресурсов оверлея
    #==========================================================================
    
    def abs_overlay_dispose_overlay
      if @abs_overlay_sprite && !@abs_overlay_sprite.disposed?
        @abs_overlay_sprite.dispose
      end

      @abs_overlay_sprite           = nil
      @abs_overlay_key_cached       = nil
      @abs_overlay_frame_counter    = 0
      @abs_overlay_current_frame    = 0
      @abs_overlay_total_frames     = 0
      @abs_last_real_x              = nil
      @abs_last_real_y              = nil
      @abs_jump_active              = nil
      @abs_jump_frame_reset         = nil
      @abs_block_active             = nil
      @abs_block_frame_reset        = nil
      @abs_attack_frame_reset       = nil
      @abs_attack_timer             = nil
      @abs_item_timer               = nil
      @abs_item_frame_reset         = nil
      @abs_skill_timer              = nil
      @abs_skill_frame_reset        = nil
      @abs_custom_timer             = nil
      @abs_custom_frame_reset       = nil
      @abs_locked_action_key        = nil
      @abs_locked_action_type       = nil
      @abs_chain_base_key           = nil
      @abs_chain_segment            = 0
      @abs_chain_enabled            = false
      @abs_death_started            = nil
      @abs_death_animation_complete = nil
      @abs_death_frame_reset        = nil
      @abs_death_original_name      = nil
      @abs_death_key_cached         = nil
    end

  end
end # class Control_Sprite_Character

#==============================================================================
# ■ Scene_Map - Отслеживание использования предметов
#------------------------------------------------------------------------------
# Перехватывает уменьшение количества предметов в инвентаре для запуска анимаций.
# Совместимо с RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

if defined?(Control_Sprite_Character)
  class Scene_Map

    #==========================================================================
    # :: Перехват метода update
    #--------------------------------------------------------------------------
    # Отслеживает использование предметов игроком через сравнение их количества.
    #==========================================================================
    
    if !method_defined?('abs_overlay_update_later')
      alias abs_overlay_update_later update
    end

    def update
      @abs_item_counts ||= {}

      if $game_player
        (1...$data_items.size).each do |item_id|
          next unless $data_items[item_id]
          
          current_count = $game_party.item_number(item_id)
          
          # Детекция использования предмета
          if !$game_player.abs_using_item
            old_count = @abs_item_counts[item_id] || current_count
            if current_count < old_count
              $game_player.abs_using_item = true
              $game_player.abs_current_item_id = item_id
            end
          end
          
          # Обновление кэша количества предметов
          @abs_item_counts[item_id] = current_count
        end
      end

      # Вызов оригинального метода update
      abs_overlay_update_later
    end

  end # class Scene_Map
end # if defined?(Control_Sprite_Character)


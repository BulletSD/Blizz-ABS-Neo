#==============================================================================
# ■ Game_Character - Расширение пользовательских анимаций
#------------------------------------------------------------------------------
# Управление пользовательскими анимациями с автоматическим расчетом длительности
# и блокировкой ввода для игрока.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

class Game_Character

  #============================================================================
  # :: Атрибуты
  #============================================================================
  
  # Флаг блокировки ввода во время пользовательской анимации (только для игрока)
  attr_accessor :abs_custom_lock_keys

  #============================================================================
  # :: Перехват метода play_custom_animation
  #--------------------------------------------------------------------------
  # Запускает пользовательскую анимацию с автоматическим расчетом длительности
  # на основе количества кадров и скорости анимации.
  #============================================================================
  
  alias abs_overlay_play_custom_animation_later play_custom_animation unless method_defined?(:abs_overlay_play_custom_animation_later)

    def play_custom_animation(animation_name, duration = 60, loop_anim = nil, allow_movement = nil)
    animation_name = animation_name.to_s

    # Автоматический расчет длительности если не указана или невалидна
    if duration.to_i < 1
      # ИСПРАВЛЕНИЕ: Гарантируем, что cfg не будет nil
      cfg = self.abs_sprite_config
      cfg = {} if cfg.nil?
      
      pic_key = cfg[animation_name.to_sym]

      # Получаем количество кадров из цепочки или одиночного файла
      frames = ABS_CustomOverlay.total_frames_for_key(self, pic_key, cfg) rescue 1
      frames = 1 if frames.nil? || frames <= 0

      # Получаем скорость анимации
      spd = ABS_CustomOverlay.get_animation_speed(:custom, animation_name)
      spd = 1 if spd.nil? || spd < 1

      duration = frames * spd
    end

    # Вызываем оригинальный метод
    abs_overlay_play_custom_animation_later(animation_name, duration, loop_anim, allow_movement)

    # Блокируем ввод для игрока если движение запрещено
    if self == $game_player && !self.abs_custom_animation_movement
      ABS_InputLock.lock
      self.abs_custom_lock_keys = true
    else
      self.abs_custom_lock_keys = false
    end
  end


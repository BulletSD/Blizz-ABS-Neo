#==============================================================================
# ■ Blizz-ABS - Инвертированная логика трупов (Corpse only if NO loot)
#------------------------------------------------------------------------------
# Изменяет логику создания трупов: труп появляется ТОЛЬКО если враг не оставил
# предметов. Если есть лут - создается только мешок с предметами без трупа.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

# Поиск целевого класса BlizzABS, содержащего метод remove_enemy
target_class = nil

if defined?(BlizzABS::Processor) && BlizzABS::Processor.instance_methods(false).include?("remove_enemy")
  target_class = BlizzABS::Processor
elsif defined?(BlizzABS) && BlizzABS.instance_methods(false).include?("remove_enemy")
  target_class = BlizzABS
end

# Применение патча, если метод найден
if target_class
  target_class.class_eval do

    #==========================================================================
    # :: Переопределение remove_enemy
    #--------------------------------------------------------------------------
    # Удаляет врага с карты, начисляет награды и создает труп/лут по новой логике.
    #==========================================================================
    
    def remove_enemy(enemy)
      # Пропускаем уже обработанных или имеющих тело врагов
      return if enemy.execute || enemy.erased || enemy.body

      # Запуск триггера смерти перед удалением
      enemy.start if enemy.trigger == BlizzABS::CETDeath

      # Удаление события с карты
      $game_map.events.delete(enemy.id)

      # Сбор выпадающих предметов
      items = drop_items(enemy)

      # Если предметы не дропаются на карту - добавляем сразу в инвентарь
      unless BlizzABS::Config::ITEM_DROP
        items.each do |item|
          case item
          when RPG::Weapon then $game_party.gain_weapon(item.id, 1)
          when RPG::Armor  then $game_party.gain_armor(item.id, 1)
          when RPG::Item   then $game_party.gain_item(item.id, 1)
          end
        end
        items = []
      end

      # Начисление опыта и золота
      exp_result(enemy)
      gold = gold_result(enemy)

      # Обработка золота в зависимости от конфигурации
      gold_cfg = BlizzABS::Config::GOLD_DROP rescue nil
      if gold_cfg.nil? || gold_cfg == ""
        $game_party.gain_gold(gold)
      elsif gold > 0
        items = [gold] + items
      end

      additional_result(enemy)

      # Размещение трупа и предметов на карте
      if BlizzABS::Config::CORPSES
        if items.size > 0
          # Есть лут - дропаем только предметы (труп не создается)
          drop_event(items, enemy.real_x, enemy.real_y, nil)
        elsif BlizzABS::Config::EMPTY_CORPSES
          # Нет лута - показываем пустой труп
          drop_event([], enemy.real_x, enemy.real_y, enemy)
        end
      else
        # Режим без трупов - каждый предмет отдельным событием
        items.each { |item| drop_event([item], enemy.real_x, enemy.real_y) }
      end
    end

  end
else
  # Предупреждение для отладки (раскомментируйте при необходимости)
  # print "ABS Invert Corpse: remove_enemy не найден в BlizzABS\n"
end

#==============================================================================
# ■ Blizz-ABS - Очистка конфигурации смерти у трупов
#------------------------------------------------------------------------------
# Сбрасывает конфигурацию анимации смерти у событий-трупов (_crp), чтобы они
# не воспроизводили анимацию смерти повторно после создания.
# Совместимость: RPG Maker XP / RGSS / Ruby 1.8.1
#==============================================================================

#==============================================================================
# ■ ABS_CorpseFixMixin - Модуль патча для drop_event
#------------------------------------------------------------------------------
# Вспомогательный модуль для применения патча к классам BlizzABS.
#==============================================================================

module ABS_CorpseFixMixin

  #============================================================================
  # :: Применение патча к целевому классу
  #============================================================================
  
  def self.apply_to(klass)
    return if klass.method_defined?(:abs_corpse_fix_drop_event)
    
    klass.class_eval do
      alias abs_corpse_fix_drop_event drop_event

      # Переопределение drop_event для очистки конфига смерти у трупов
      def drop_event(items, x, y, dropper = nil)
        result = abs_corpse_fix_drop_event(items, x, y, dropper)

        # Применяем патч только если есть dropper (враг) и результат
        if dropper && result
          # Нормализуем результат в массив
          events = Array(result)

          events.each do |ev|
            next unless ev

            # Получаем имя персонажа
            cname = ev.character_name.to_s rescue ""
            
            # Проверяем, является ли событие трупом (суффикс _crp)
            next unless cname =~ /_crp$/i

            # Получаем конфигурацию спрайтов
            cfg = ev.abs_sprite_config rescue nil
            next unless cfg

            # Удаляем ключ смерти и сбрасываем флаги анимации
            cfg.delete(:death)
            ev.instance_variable_set(:@abs_death_started, nil)
            ev.instance_variable_set(:@abs_death_animation_complete, true)
            ev.instance_variable_set(:@abs_death_frame_reset, nil)
            ev.instance_variable_set(:@abs_death_original_name, nil)
          end
        end

        result
      end

    end
  end

end

